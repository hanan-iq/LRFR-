@torch.no_grad()
def run_recognition_r100_batch(imgs_bgr: list, start_bs: int = 96) -> np.ndarray:
    """
    Drop-in replacement for run_recognition_onnx_with_fallback.
    Takes a list of BGR numpy images, returns (N, 512) float32 features.
    Uses the global `rec_model` (PyTorch R100) loaded above.
    """
    rec_model.eval()
    all_feats = []
    if len(imgs_bgr) == 0:
        return np.zeros((0, 512), dtype=np.float32)
    bs = max(1, min(int(start_bs), len(imgs_bgr)))

    for i in range(0, len(imgs_bgr), bs):
        batch_imgs = imgs_bgr[i : i + bs]
        tensors = []
        for img in batch_imgs:
            # BGR → RGB → resize 112×112 → normalize
            rgb = cv2.cvtColor(img[:, :, :3], cv2.COLOR_BGR2RGB)
            rgb = cv2.resize(rgb, (112, 112), interpolation=cv2.INTER_LINEAR)
            t = torch.from_numpy(rgb.transpose(2, 0, 1)).float().div(255.0)
            t = (t - 0.5) / 0.5
            tensors.append(t)

        batch = torch.stack(tensors).to(DEVICE)
        out = rec_model(batch)

        if isinstance(out, tuple):
            feat, norm = out
        else:
            norm = torch.norm(out, 2, 1, True)
            feat = out / norm

        all_feats.append(feat.cpu().numpy())

    return np.concatenate(all_feats, axis=0).astype(np.float32)


