    # The final comparison is restricted to the protected Q-PEARL result and Q-PEARL-Adapter++.
    best_name, best_res = max(candidates, key=lambda item: qpearl_adapter_metric_tuple(item[1]))
    OBJ3_RESULTS["TinyFace_selected_after_adapter"] = best_res
    OBJ3_RESULTS["TinyFace"] = best_res

    if best_name == "Q-PEARL-Adapter++":
