class QPEARLV2Reranker(nn.Module):
    def __init__(self, input_dim=9, hidden_dim=64):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(0.10),
            nn.Linear(hidden_dim, hidden_dim // 2),
            nn.ReLU(inplace=True),
            nn.Linear(hidden_dim // 2, 1),
        )

    def forward(self, x):
        return self.net(x).view(-1)

def qpearl_v2_build_prototypes(G, G_ids):
    G_ids = np.asarray(G_ids).astype(str)
    mask = G_ids != "-1"
    if mask.sum() == 0:
        return np.zeros((0, G.shape[1]), dtype=np.float32), np.asarray([], dtype=str)
    proto, proto_ids, _ = build_identity_prototypes(G[mask], G_ids[mask], G_quality=None)
    return l2n_rows(proto), np.asarray(proto_ids).astype(str)

def qpearl_v2_candidate_features(
    P_r100, G_r100, P_v2, G_v2, P_ids, G_ids, P_q, G_q,
    k: int = 100,
    sample_neg_per_probe: Optional[int] = None,
    include_labels: bool = True,
):
    P_r100 = l2n_rows(P_r100); G_r100 = l2n_rows(G_r100)
    P_v2 = l2n_rows(P_v2); G_v2 = l2n_rows(G_v2)
    P_ids = np.asarray(P_ids).astype(str); G_ids = np.asarray(G_ids).astype(str)
    P_q = np.asarray(P_q, dtype=np.float32); G_q = np.asarray(G_q, dtype=np.float32)

    Proto, Proto_ids = qpearl_v2_build_prototypes(G_v2, G_ids)
    proto_index = {pid: i for i, pid in enumerate(Proto_ids)}
    rows = []
    groups = []

    for start in tqdm(range(0, len(P_ids), int(CONFIG["qpearl_v2_candidate_batch"])), desc="Build reranker candidates", leave=False):
        stop = min(start + int(CONFIG["qpearl_v2_candidate_batch"]), len(P_ids))
        sr = np.dot(P_r100[start:stop], G_r100.T).astype(np.float32)
        sv = np.dot(P_v2[start:stop], G_v2.T).astype(np.float32)
        sf = 0.30 * sr + 0.60 * sv
        kk = min(int(k), sf.shape[1])
        idx = np.argpartition(-sf, kth=kk - 1, axis=1)[:, :kk]
        sf_top = np.take_along_axis(sf, idx, axis=1)
        order = np.argsort(-sf_top, axis=1)
        idx = np.take_along_axis(idx, order, axis=1)

        sr_rank = np.argsort(np.argsort(-sr, axis=1), axis=1)
        sv_rank = np.argsort(np.argsort(-sv, axis=1), axis=1)

        for bi in range(stop - start):
            true_id = P_ids[start + bi]
            cand = idx[bi]
            if sample_neg_per_probe is not None and include_labels:
                pos = [j for j in cand if G_ids[j] == true_id]
                neg = [j for j in cand if G_ids[j] != true_id]
                if len(neg) > int(sample_neg_per_probe):
                    rng = np.random.default_rng(SEED + start + bi)
                    neg = rng.choice(neg, size=int(sample_neg_per_probe), replace=False).tolist()
                cand = np.asarray(pos + neg, dtype=np.int64)

            margin = float(sf_top[bi, 0] - sf_top[bi, 1]) if sf_top.shape[1] > 1 else 0.0
            group_indices = []
            for j in cand:
                pid = str(G_ids[j])
                pidx = proto_index.get(pid, None)
                proto_sim = float(np.dot(P_v2[start + bi], Proto[pidx])) if pidx is not None else 0.0
                features = [
                    float(sr[bi, j]),
                    float(sv[bi, j]),
                    float(1.0 / (1.0 + sr_rank[bi, j])),
                    float(1.0 / (1.0 + sv_rank[bi, j])),
                    float(proto_sim),
                    float(sf[bi, j]),
                    float(P_q[start + bi]),
                    float(G_q[j]),
                    float(margin),
                ]
                label = 1.0 if pid == true_id else 0.0
                rows.append((start + bi, int(j), pid, true_id, features, label))
                group_indices.append(len(rows) - 1)
            groups.append(group_indices)
    return rows, groups

def qpearl_v2_rows_to_tensors(rows):
    X = np.asarray([r[4] for r in rows], dtype=np.float32)
    y = np.asarray([r[5] for r in rows], dtype=np.float32)
    return torch.tensor(X, dtype=torch.float32), torch.tensor(y, dtype=torch.float32)

