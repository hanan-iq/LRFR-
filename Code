def qpearl_v2_quality_stats_from_cache(cache: Dict[str, np.ndarray]) -> Dict[str, float]:
    q = np.asarray(cache["quality_train"], dtype=np.float32)
    q = q[np.isfinite(q)]
    if q.size == 0:
        return {"lo": 0.0, "hi": 1.0, "mean": 0.5}
    lo = float(np.percentile(q, 5))
    hi = float(np.percentile(q, 95))
    if hi <= lo:
        hi = lo + 1e-6
    return {"lo": lo, "hi": hi, "mean": float(np.mean(q))}

QPEARL_V2_QUALITY_STATS = qpearl_v2_quality_stats_from_cache(QPEARL_V2_CACHE)

def qpearl_v2_normalize_quality(q):
    arr = np.asarray(q, dtype=np.float32)
    lo = QPEARL_V2_QUALITY_STATS["lo"]
    hi = QPEARL_V2_QUALITY_STATS["hi"]
    out = (arr - lo) / (hi - lo + 1e-6)
    return np.clip(out, 0.0, 1.0).astype(np.float32)

