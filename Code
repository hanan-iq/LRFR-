def qpearl_v2_bgr_to_tensor(img_bgr: np.ndarray, size: Optional[int] = None) -> torch.Tensor:
    if size is None:
        size = int(CONFIG["qpearl_v2_img_size"])
    if img_bgr is None:
        img_bgr = np.zeros((size, size, 3), dtype=np.uint8)
    img = cv2.resize(img_bgr, (size, size), interpolation=cv2.INTER_CUBIC)
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB).astype(np.float32) / 255.0
    img = (img - 0.5) / 0.5
    img = np.transpose(img, (2, 0, 1))
    return torch.from_numpy(img.astype(np.float32))

def qpearl_v2_degrade_lr(img_bgr: np.ndarray) -> np.ndarray:
    sizes = CONFIG.get("qpearl_lr_degrade_sizes", [16, 20, 24, 32])
    s = int(random.choice(sizes))
    h, w = img_bgr.shape[:2]
    small = cv2.resize(img_bgr, (s, s), interpolation=cv2.INTER_AREA)
    restored = cv2.resize(small, (w, h), interpolation=cv2.INTER_CUBIC)
    if random.random() < float(CONFIG.get("qpearl_align_blur_prob", 0.35)):
        sig = random.uniform(*CONFIG.get("qpearl_align_blur_sigma", [0.4, 1.1]))
        restored = cv2.GaussianBlur(restored, (0, 0), sig)
    if random.random() < float(CONFIG.get("qpearl_align_jpeg_prob", 0.25)):
        q = int(random.uniform(*CONFIG.get("qpearl_align_jpeg_quality_range", [40, 85])))
        ok, enc = cv2.imencode(".jpg", restored, [int(cv2.IMWRITE_JPEG_QUALITY), q])
        if ok:
            restored = cv2.imdecode(enc, cv2.IMREAD_COLOR)
    return restored

def qpearl_v2_global_transform(img_bgr: np.ndarray) -> np.ndarray:
    h, w = img_bgr.shape[:2]
    rot = random.uniform(-10.0, 10.0)
    scale = random.uniform(0.85, 1.15)
    tx = random.uniform(-6.0, 6.0)
    ty = random.uniform(-6.0, 6.0)
    M = cv2.getRotationMatrix2D((w / 2, h / 2), rot, scale)
    M[:, 2] += [tx, ty]
    return cv2.warpAffine(img_bgr, M, (w, h), flags=cv2.INTER_LINEAR, borderMode=cv2.BORDER_REFLECT_101)

def qpearl_v2_elastic_deform(img_bgr: np.ndarray, alpha: float = 1.4, sigma: float = 10.0) -> np.ndarray:
    h, w = img_bgr.shape[:2]
    rng = np.random.default_rng()
    dx = rng.normal(0, 1, (h, w)).astype(np.float32)
    dy = rng.normal(0, 1, (h, w)).astype(np.float32)
    dx = cv2.GaussianBlur(dx, (0, 0), sigma) * alpha
    dy = cv2.GaussianBlur(dy, (0, 0), sigma) * alpha
    x, y = np.meshgrid(np.arange(w), np.arange(h))
    map_x = (x + dx).astype(np.float32)
    map_y = (y + dy).astype(np.float32)
    return cv2.remap(img_bgr, map_x, map_y, interpolation=cv2.INTER_LINEAR, borderMode=cv2.BORDER_REFLECT_101)

class QPEARLV2TrainDataset(Dataset):
    def __init__(self, paths, ids, teacher, quality, id_to_label: Dict[str, int], train: bool = True):
        self.paths = np.asarray(paths).astype(str)
        self.ids = np.asarray(ids).astype(str)
        self.teacher = np.asarray(teacher, dtype=np.float32)
        self.quality_raw = np.asarray(quality, dtype=np.float32)
        self.quality = qpearl_v2_normalize_quality(self.quality_raw)
        self.id_to_label = dict(id_to_label)
        self.train = bool(train)

    def __len__(self):
        return len(self.paths)

    def __getitem__(self, idx):
        path = str(self.paths[idx])
        img = safe_imread(path)
        if img is None:
            img = np.zeros((112, 112, 3), dtype=np.uint8)

        clean = img
        lr = qpearl_v2_degrade_lr(img)
        glob = qpearl_v2_global_transform(img)
        if random.random() < float(CONFIG.get("qpearl_align_elastic_prob", 0.40)):
            elastic = qpearl_v2_elastic_deform(
                img,
                alpha=float(CONFIG.get("qpearl_align_elastic_alpha", 1.4)),
                sigma=float(CONFIG.get("qpearl_align_elastic_sigma", 10.0)),
            )
        else:
            elastic = img.copy()

        label = int(self.id_to_label[str(self.ids[idx])])
        return {
            "x_clean": qpearl_v2_bgr_to_tensor(clean),
            "x_lr": qpearl_v2_bgr_to_tensor(lr),
            "x_global": qpearl_v2_bgr_to_tensor(glob),
            "x_elastic": qpearl_v2_bgr_to_tensor(elastic),
            "teacher": torch.from_numpy(self.teacher[idx]).float(),
            "quality": torch.tensor(float(self.quality[idx]), dtype=torch.float32),
            "label": torch.tensor(label, dtype=torch.long),
            "person_id": str(self.ids[idx]),
            "path": path,
        }

