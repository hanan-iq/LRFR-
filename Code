def _tar_at_far(fpr_array, tpr_array, far_value):
    """
    TAR@FAR is computed as the maximum TAR/TPR under FPR <= FAR.
    """
    mask = fpr_array <= float(far_value)

    if not np.any(mask):
        return 0.0

    return float(np.max(tpr_array[mask]))


def _format_percent_numeric(value):
    if value is None or not np.isfinite(value):
        return np.nan
    return round(float(value), 2)


def _format_percent_text(value):
    if value is None or not np.isfinite(value):
        return "—"
    return f"{float(value):.2f}%"


def _rank1_by_quality_quartile(ranks, quality):
    labels = [
        "Q1 Rank-1, lowest quality",
        "Q2 Rank-1",
        "Q3 Rank-1",
        "Q4 Rank-1, highest quality",
    ]

    valid_q = np.isfinite(quality)
    qvals = quality[valid_q]

    if len(qvals) == 0:
        return [(label, np.nan, 0) for label in labels]

    edges = np.quantile(qvals, [0.0, 0.25, 0.50, 0.75, 1.0])
    rows = []

    for i, label in enumerate(labels):
        if i < 3:
            mask = valid_q & (quality >= edges[i]) & (quality < edges[i + 1])
        else:
            mask = valid_q & (quality >= edges[i]) & (quality <= edges[i + 1])

        n = int(mask.sum())

        if n == 0:
            rank1 = np.nan
        else:
            # Notebook convention: probe_ranks == 0 means correct identity at Rank-1.
            rank1 = 100.0 * float(np.mean(ranks[mask] == 0))

        rows.append((label, rank1, n))

    return rows


# ------------------------------------------------------------
# 5. Compute TAR@FAR operating points
# ------------------------------------------------------------
operating_rows = []

tar_far_specs = [
    ("TAR@FAR = 10⁻¹", 1e-1),
    ("TAR@FAR = 10⁻²", 1e-2),
    ("TAR@FAR = 10⁻³", 1e-3),
]

for label, far_value in tar_far_specs:
    tar = 100.0 * _tar_at_far(fpr, tpr, far_value)
    operating_rows.append({
        "Metric": label,
        "Value (%)": _format_percent_numeric(tar),
        "Value": _format_percent_text(tar),
        "N": "",
        "Source": "ROC",
    })


# ------------------------------------------------------------
# 6. Compute quality-stratified Rank-1
# ------------------------------------------------------------
quartile_rows = _rank1_by_quality_quartile(probe_ranks, probe_quality)

for label, rank1, n in quartile_rows:
    operating_rows.append({
        "Metric": label,
        "Value (%)": _format_percent_numeric(rank1),
        "Value": _format_percent_text(rank1),
        "N": n,
        "Source": "Quality quartile",
    })

operating_df = pd.DataFrame(operating_rows)


