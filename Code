def qpearl_v2_compute_map_from_ranks(ranks: np.ndarray) -> float:
    """
    Compute mAP for single-ground-truth TinyFace identification.

    Failed probes must contribute 0, not be excluded.
    This avoids inflating mAP when the correct identity is missing from the candidate list.
    """
    ranks = np.asarray(ranks, dtype=np.int64)
    if ranks.size == 0:
        return float("nan")
    ap = np.zeros(ranks.shape[0], dtype=np.float32)
    valid = ranks >= 0
    ap[valid] = 1.0 / (ranks[valid].astype(np.float32) + 1.0)
    return float(np.mean(ap))

def qpearl_v2_cmc_from_ranks(ranks: np.ndarray, max_rank: int = 100):
    ranks = np.asarray(ranks, dtype=np.int64)
    cmc = []
    for k in range(1, max_rank + 1):
        cmc.append(float(np.mean((ranks >= 0) & (ranks < k))))
    return np.arange(1, max_rank + 1), np.asarray(cmc, dtype=np.float32)

def qpearl_v2_eval_plain(P, P_ids, G, G_ids, D=None, D_ids=None, name="plain"):
    blocks = [(G, G_ids)]
    if D is not None and len(D) > 0:
        if D_ids is None:
            D_ids = np.asarray(["-1"] * len(D), dtype=str)
        blocks.append((D, D_ids))
    out = evaluate_identification_chunked(
        P,
        P_ids,
        blocks,
        ranks=(1, 5, 10, 20),
        probe_batch=int(CONFIG["tinyface_probe_batch"]),
        aux_neg_per_probe=CONFIG["tinyface_aux_neg_per_probe"],
        seed=SEED,
    )
    out["name"] = name
    return out

def qpearl_v2_fused_scores_chunk(P_r100, G_r100, P_v2, G_v2, P_q, w=(0.30, 0.60, 0.10)):
    s_r100 = np.dot(P_r100, G_r100.T).astype(np.float32)
    s_v2 = np.dot(P_v2, G_v2.T).astype(np.float32)
    q = np.asarray(P_q, dtype=np.float32).reshape(-1, 1)
    adaptive_v2 = (0.50 + 0.20 * (1.0 - q)) * s_v2
    return float(w[0]) * s_r100 + float(w[1]) * adaptive_v2

def qpearl_v2_eval_fusion(P_r100, G_r100, P_v2, G_v2, P_ids, G_ids, P_q, topk: int = 100, name="fusion"):
    n = len(P_ids)
    max_rank = max(20, int(topk))
    hits = {1: 0, 5: 0, 10: 0, 20: 0}
    ranks = np.full(n, -1, dtype=np.int32)

    for start in tqdm(range(0, n, int(CONFIG["tinyface_probe_batch"])), desc=f"Eval {name}", leave=False):
        stop = min(start + int(CONFIG["tinyface_probe_batch"]), n)
        scores = qpearl_v2_fused_scores_chunk(
            P_r100[start:stop],
            G_r100,
            P_v2[start:stop],
            G_v2,
            P_q[start:stop],
        )
        k = min(max_rank, scores.shape[1])
        idx = np.argpartition(-scores, kth=k - 1, axis=1)[:, :k]
        scr = np.take_along_axis(scores, idx, axis=1)
        order = np.argsort(-scr, axis=1)
        idx = np.take_along_axis(idx, order, axis=1)
        pred_ids = G_ids[idx]
        for i, true_id in enumerate(P_ids[start:stop]):
            row = pred_ids[i]
            loc = np.where(row == true_id)[0]
            if len(loc) > 0:
                r = int(loc[0])
                ranks[start + i] = r
                for kk in hits:
                    if r < kk:
                        hits[kk] += 1

    out = {f"rank_{k}": float(v / n) for k, v in hits.items()}
    out["mAP"] = qpearl_v2_compute_map_from_ranks(ranks)
    out["probe_ranks"] = ranks
    out["name"] = name
    return out

