def parse_pairs_file(pairs_path: str) -> List[Tuple[str, int, str, int, bool]]:
    parsed = []
    with open(pairs_path, "r") as f:
        lines = [ln.strip() for ln in f.readlines() if ln.strip()]
    for line in lines[1:]:
        parts = line.split()
        if len(parts) == 3:
            name, idx1, idx2 = parts[0], int(parts[1]), int(parts[2])
            parsed.append((name, idx1, name, idx2, True))
        elif len(parts) == 4:
            n1, i1, n2, i2 = parts[0], int(parts[1]), parts[2], int(parts[3])
            parsed.append((n1, i1, n2, i2, False))
    return parsed

def pair_to_path(root: str, name: str, idx: int) -> str:
    return os.path.join(root, name, f"{name}_{idx:04d}.jpg")

def assign_folds(n_items: int, n_folds: int = 10) -> np.ndarray:
    if n_items == 6000 and n_folds == 10:
        return np.repeat(np.arange(10), 600)
    sizes = [n_items // n_folds] * n_folds
    for i in range(n_items % n_folds):
        sizes[i] += 1
    out = []
    for fold, sz in enumerate(sizes):
        out.extend([fold] * sz)
    return np.array(out, dtype=np.int32)

def best_threshold_from_train(train_scores: np.ndarray, train_labels: np.ndarray) -> float:
    thresholds = np.linspace(-1.0, 1.0, CONFIG["pair_threshold_steps"], dtype=np.float32)
    preds = train_scores[:, None] > thresholds[None, :]
    accs = (preds == train_labels[:, None]).mean(axis=0)
    return float(thresholds[np.argmax(accs)])

def score_dataset_key(root: str, lr_size: Optional[int]) -> str:
    root_low = root.lower()
    if "xqlfw" in root_low:
        return "xqlfw"
    if lr_size == CONFIG["lr16"]:
        return "lr16"
    if lr_size == CONFIG["lr32"]:
        return "lr32"
    return "hr"

def obj2_asnorm_weight(dataset_key: str) -> float:
    return {
        "hr": CONFIG["obj2_asnorm_w_hr"],
        "lr32": CONFIG["obj2_asnorm_w_lr32"],
        "lr16": CONFIG["obj2_asnorm_w_lr16"],
        "xqlfw": CONFIG["obj2_asnorm_w_xqlfw"],
    }[dataset_key]

def prepare_pairs_embeddings(
    root: str,
    pairs_path: str,
    lr_size: Optional[int],
    cache_stage: str,
    adapter: Optional[nn.Module] = None,
) -> Tuple[List[Tuple[str, str, bool]], List[str], Dict[str, np.ndarray], Dict[str, float]]:
    parsed = parse_pairs_file(pairs_path)
    valid = []
    uniq_paths = set()
    for n1, i1, n2, i2, same in parsed:
        p1 = pair_to_path(root, n1, i1)
        p2 = pair_to_path(root, n2, i2)
        if os.path.exists(p1) and os.path.exists(p2):
            uniq_paths.add(p1)
            uniq_paths.add(p2)
            valid.append((p1, p2, same))

    uniq_paths = list(uniq_paths)
    embs = extract_embeddings_from_paths(uniq_paths, lr_size=lr_size, stage=cache_stage, adapter=adapter, use_flip=True)
    quals = get_qualities_for_paths(uniq_paths, lr_size=lr_size, stage=cache_stage)
    path_to_emb = {p: e for p, e in zip(uniq_paths, embs)}
    path_to_q = {p: float(q) for p, q in zip(uniq_paths, quals)}
    return valid, uniq_paths, path_to_emb, path_to_q

def evaluate_pairs_cv_raw(
    root: str,
    pairs_path: str,
    lr_size: Optional[int],
    cache_stage: str,
    adapter: Optional[nn.Module],
    name: str,
) -> Dict[str, float]:
    valid, _, path_to_emb, _ = prepare_pairs_embeddings(root, pairs_path, lr_size, cache_stage, adapter)

    sims, labels = [], []
    for p1, p2, same in tqdm(valid, desc=name, leave=False):
        sims.append(float(np.dot(path_to_emb[p1], path_to_emb[p2])))
        labels.append(bool(same))

    sims = np.asarray(sims, dtype=np.float32)
    labels = np.asarray(labels, dtype=bool)
    folds = assign_folds(len(sims), n_folds=CONFIG["pair_folds"])

    fold_accs, fold_thresholds = [], []
    for fold in range(CONFIG["pair_folds"]):
        train_mask = folds != fold
        test_mask = folds == fold
        thr = best_threshold_from_train(sims[train_mask], labels[train_mask])
        acc = float(((sims[test_mask] > thr) == labels[test_mask]).mean())
        fold_accs.append(acc)
        fold_thresholds.append(thr)

    fpr, tpr, _ = roc_curve(labels.astype(np.int32), sims)
    roc_auc = float(auc(fpr, tpr))
    return {
        "accuracy": float(np.mean(fold_accs)),
        "std": float(np.std(fold_accs)),
        "fold_accs": [float(x) for x in fold_accs],
        "fold_thresholds": [float(x) for x in fold_thresholds],
        "n_folds": int(len(fold_accs)),
        "AUC": roc_auc,
        "threshold_mean": float(np.mean(fold_thresholds)),
        "threshold_std": float(np.std(fold_thresholds)),
        "n_pairs": int(len(sims)),
    }

def compute_asnorm_stats(
    target_paths: List[str],
    cohort_paths: List[str],
    path_to_emb: Dict[str, np.ndarray],
    topk: int,
    batch_size: int = CONFIG["pair_asnorm_batch"],
) -> Dict[str, Tuple[float, float]]:
    cohort_paths = list(dict.fromkeys(cohort_paths))
    if len(cohort_paths) == 0:
        return {p: (0.0, 1.0) for p in target_paths}

    cohort_embs = np.stack([path_to_emb[p] for p in cohort_paths]).astype(np.float32)
    cohort_embs = l2n_rows(cohort_embs)
    cohort_index = {p: i for i, p in enumerate(cohort_paths)}
    stats = {}

    for start in range(0, len(target_paths), batch_size):
        chunk_paths = target_paths[start:start + batch_size]
        Q = np.stack([path_to_emb[p] for p in chunk_paths]).astype(np.float32)
        Q = l2n_rows(Q)
        sims = np.dot(Q, cohort_embs.T).astype(np.float32)

        for i, p in enumerate(chunk_paths):
            j = cohort_index.get(p)
            if j is not None:
                sims[i, j] = -np.inf

        k = min(topk, sims.shape[1])
        if k <= 0:
            for p in chunk_paths:
                stats[p] = (0.0, 1.0)
            continue

        idx = np.argpartition(-sims, kth=k - 1, axis=1)[:, :k]
        top = np.take_along_axis(sims, idx, axis=1)
        mu = np.mean(top, axis=1)
        sd = np.std(top, axis=1) + 1e-6
        for p, m, s in zip(chunk_paths, mu, sd):
            stats[p] = (float(m), float(s))
    return stats

def evaluate_pairs_cv_obj2(
    root: str,
    pairs_path: str,
    lr_size: Optional[int],
    cache_stage: str,
    adapter: Optional[nn.Module],
    name: str,
) -> Dict[str, float]:
    valid, uniq_paths, path_to_emb, _ = prepare_pairs_embeddings(root, pairs_path, lr_size, cache_stage, adapter)
    labels = np.asarray([bool(s) for _, _, s in valid], dtype=bool)
    folds = assign_folds(len(valid), n_folds=CONFIG["pair_folds"])
    dataset_key = score_dataset_key(root, lr_size)
    base_as_w = obj2_asnorm_weight(dataset_key)

    all_scores = np.zeros(len(valid), dtype=np.float32)
    fold_accs, fold_thresholds = [], []

    for fold in range(CONFIG["pair_folds"]):
        train_idx = np.where(folds != fold)[0]
        test_idx = np.where(folds == fold)[0]

        train_paths = []
        for i in train_idx:
            train_paths.extend([valid[i][0], valid[i][1]])
        cohort_paths = list(dict.fromkeys(train_paths))
        stats = compute_asnorm_stats(uniq_paths, cohort_paths, path_to_emb, topk=CONFIG["pair_asnorm_topk"])

        def pair_score(i: int) -> float:
            p1, p2, _ = valid[i]
            raw = float(np.dot(path_to_emb[p1], path_to_emb[p2]))
            m1, s1 = stats[p1]
            m2, s2 = stats[p2]
            sn = 0.5 * (((raw - m1) / s1) + ((raw - m2) / s2))
            return float((1.0 - base_as_w) * raw + base_as_w * sn)

        train_scores = np.asarray([pair_score(i) for i in train_idx], dtype=np.float32)
        test_scores = np.asarray([pair_score(i) for i in test_idx], dtype=np.float32)

        all_scores[test_idx] = test_scores
        thr = best_threshold_from_train(train_scores, labels[train_idx])
        acc = float(((test_scores > thr) == labels[test_idx]).mean())
        fold_accs.append(acc)
        fold_thresholds.append(thr)

    fpr, tpr, _ = roc_curve(labels.astype(np.int32), all_scores)
    roc_auc = float(auc(fpr, tpr))
    return {
        "accuracy": float(np.mean(fold_accs)),
        "std": float(np.std(fold_accs)),
        "fold_accs": [float(x) for x in fold_accs],
        "fold_thresholds": [float(x) for x in fold_thresholds],
        "n_folds": int(len(fold_accs)),
        "AUC": roc_auc,
        "threshold_mean": float(np.mean(fold_thresholds)),
        "threshold_std": float(np.std(fold_thresholds)),
        "n_pairs": int(len(valid)),
    }

def evaluate_pairs_cv_obj3(
    root: str,
    pairs_path: str,
    lr_size: Optional[int],
    cache_stage: str,
    adapter: Optional[nn.Module],
    name: str,
) -> Dict[str, float]:
    valid, uniq_paths, path_to_emb, path_to_q = prepare_pairs_embeddings(root, pairs_path, lr_size, cache_stage, adapter)
    labels = np.asarray([bool(s) for _, _, s in valid], dtype=bool)
    folds = assign_folds(len(valid), n_folds=CONFIG["pair_folds"])
    dataset_key = score_dataset_key(root, lr_size)
    base_as_w = obj2_asnorm_weight(dataset_key)

    all_scores = np.zeros(len(valid), dtype=np.float32)
    fold_accs, fold_thresholds = [], []
    fold_diag = []

    for fold in range(CONFIG["pair_folds"]):
        train_idx = np.where(folds != fold)[0]
        test_idx = np.where(folds == fold)[0]

        train_paths = []
        for i in train_idx:
            train_paths.extend([valid[i][0], valid[i][1]])
        cohort_paths = list(dict.fromkeys(train_paths))
        stats = compute_asnorm_stats(uniq_paths, cohort_paths, path_to_emb, topk=CONFIG["pair_asnorm_topk"])

        train_pair_q = np.asarray([min(path_to_q[valid[i][0]], path_to_q[valid[i][1]]) for i in train_idx], dtype=np.float32)
        q_lo = float(np.percentile(train_pair_q, 25))
        q_hi = float(np.percentile(train_pair_q, 75))
        q_mu = float(train_pair_q.mean())
        q_sd = float(train_pair_q.std() + 1e-6)

        def pair_score(i: int) -> float:
            p1, p2, _ = valid[i]
            raw = float(np.dot(path_to_emb[p1], path_to_emb[p2]))
            m1, s1 = stats[p1]
            m2, s2 = stats[p2]
            sn = 0.5 * (((raw - m1) / s1) + ((raw - m2) / s2))

            qpair = float(min(path_to_q[p1], path_to_q[p2]))
            lowq = np.clip((q_hi - qpair) / (q_hi - q_lo + 1e-10), 0.0, 1.0)
            w_as = np.clip(base_as_w + CONFIG["obj3_extra_asnorm_gain"] * lowq, 0.05, 0.85)
            w_raw = 1.0 - w_as

            q_prior = (qpair - q_mu) / q_sd
            return float(w_raw * raw + w_as * sn + CONFIG["obj3_quality_prior_weight"] * q_prior)

        train_scores = np.asarray([pair_score(i) for i in train_idx], dtype=np.float32)
        test_scores = np.asarray([pair_score(i) for i in test_idx], dtype=np.float32)

        all_scores[test_idx] = test_scores
        thr = best_threshold_from_train(train_scores, labels[train_idx])
        acc = float(((test_scores > thr) == labels[test_idx]).mean())
        fold_accs.append(acc)
        fold_thresholds.append(thr)
        fold_diag.append({
            "fold": int(fold),
            "q_lo": q_lo,
            "q_hi": q_hi,
            "threshold": float(thr),
        })

    fpr, tpr, _ = roc_curve(labels.astype(np.int32), all_scores)
    roc_auc = float(auc(fpr, tpr))
    return {
        "accuracy": float(np.mean(fold_accs)),
        "std": float(np.std(fold_accs)),
        "fold_accs": [float(x) for x in fold_accs],
        "fold_thresholds": [float(x) for x in fold_thresholds],
        "n_folds": int(len(fold_accs)),
        "AUC": roc_auc,
        "threshold_mean": float(np.mean(fold_thresholds)),
        "threshold_std": float(np.std(fold_thresholds)),
        "n_pairs": int(len(valid)),
        "score_mean": float(np.mean(all_scores)),
        "score_std": float(np.std(all_scores)),
        "fold_diag": fold_diag,
    }

