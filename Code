class LoRALinearQuality(nn.Module):
    """
    Quality-aware low-rank residual for a frozen Linear layer.
    The base layer is frozen. Two LoRA experts are blended by a scalar quality gate.
    """
    def __init__(self, base: nn.Linear, rank: int = 8, alpha: float = 16.0, dropout: float = 0.05):
        super().__init__()
        self.base = base
        for p in self.base.parameters():
            p.requires_grad_(False)

        in_features = base.in_features
        out_features = base.out_features
        self.rank = int(rank)
        self.scale = float(alpha) / max(1, self.rank)
        self.drop = nn.Dropout(float(dropout))

        self.low_A = nn.Linear(in_features, self.rank, bias=False)
        self.low_B = nn.Linear(self.rank, out_features, bias=False)
        self.high_A = nn.Linear(in_features, self.rank, bias=False)
        self.high_B = nn.Linear(self.rank, out_features, bias=False)

        nn.init.kaiming_uniform_(self.low_A.weight, a=math.sqrt(5))
        nn.init.zeros_(self.low_B.weight)
        nn.init.kaiming_uniform_(self.high_A.weight, a=math.sqrt(5))
        nn.init.zeros_(self.high_B.weight)

        self.quality_scalar = 0.5

    def set_quality_scalar(self, value: float):
        self.quality_scalar = float(np.clip(value, 0.0, 1.0))

    def forward(self, x):
        base_out = self.base(x)
        z = self.drop(x)
        low = self.low_B(self.low_A(z))
        high = self.high_B(self.high_A(z))
        q = self.quality_scalar
        return base_out + self.scale * ((1.0 - q) * low + q * high)

def qpearl_v2_replace_qkv_with_lora(module: nn.Module, rank: int, alpha: float, dropout: float) -> int:
    replaced = 0
    for name, child in list(module.named_children()):
        if isinstance(child, nn.Linear) and name in {"qkv", "proj"}:
            setattr(module, name, LoRALinearQuality(child, rank=rank, alpha=alpha, dropout=dropout))
            replaced += 1
        else:
            replaced += qpearl_v2_replace_qkv_with_lora(child, rank=rank, alpha=alpha, dropout=dropout)
    return replaced

def qpearl_v2_set_quality_scalar(module: nn.Module, quality: torch.Tensor):
    q = float(torch.clamp(quality.detach().float().mean(), 0.0, 1.0).item())
    for m in module.modules():
        if isinstance(m, LoRALinearQuality):
            m.set_quality_scalar(q)

class TinyFallbackBackbone(nn.Module):
    """
    Debug fallback only. It keeps the notebook executable when timm or pretrained Swin weights are unavailable.
    Do not use fallback results as the final paper result.
    """
    def __init__(self, out_dim=512):
        super().__init__()
        self.net = nn.Sequential(
            nn.Conv2d(3, 64, 3, stride=2, padding=1), nn.BatchNorm2d(64), nn.ReLU(inplace=True),
            nn.Conv2d(64, 128, 3, stride=2, padding=1), nn.BatchNorm2d(128), nn.ReLU(inplace=True),
            nn.Conv2d(128, 256, 3, stride=2, padding=1), nn.BatchNorm2d(256), nn.ReLU(inplace=True),
            nn.Conv2d(256, 512, 3, stride=2, padding=1), nn.BatchNorm2d(512), nn.ReLU(inplace=True),
            nn.AdaptiveAvgPool2d(1),
        )
        self.num_features = 512

    def forward(self, x):
        return self.net(x).flatten(1)

class QPEARLV2Model(nn.Module):
    def __init__(self, embedding_dim: int = 512):
        super().__init__()
        self.embedding_dim = int(embedding_dim)
        self.uses_timm = False

        timm = _try_import_timm()
        if timm is not None:
            try:
                self.backbone = timm.create_model(
                    CONFIG["qpearl_v2_backbone"],
                    pretrained=bool(CONFIG["qpearl_v2_pretrained"]),
                    num_classes=0,
                    global_pool="avg",
                )
                self.uses_timm = True
                print(f"[OK] Loaded timm backbone: {CONFIG['qpearl_v2_backbone']}")
            except Exception as e:
                if not CONFIG.get("qpearl_v2_allow_debug_fallback", False):
                    raise RuntimeError(
                        "Could not load the required Swin-B timm backbone for final Q-PEARL-v2. "
                        "Set CONFIG['qpearl_v2_allow_debug_fallback']=True only for debugging, not for paper results. "
                        f"Original error: {e}"
                    )
                print(f"[WARNING] Could not load Swin-B backbone: {e}")
                print("[WARNING] Falling back to TinyFallbackBackbone for debugging.")
                self.backbone = TinyFallbackBackbone(out_dim=embedding_dim)
        else:
            if not CONFIG.get("qpearl_v2_allow_debug_fallback", False):
                raise RuntimeError("timm backbone is unavailable and debug fallback is disabled.")
            self.backbone = TinyFallbackBackbone(out_dim=embedding_dim)

        for p in self.backbone.parameters():
            p.requires_grad_(False)

        replaced = 0
        if self.uses_timm:
            replaced = qpearl_v2_replace_qkv_with_lora(
                self.backbone,
                rank=int(CONFIG["qpearl_v2_lora_rank"]),
                alpha=float(CONFIG["qpearl_v2_lora_alpha"]),
                dropout=float(CONFIG["qpearl_v2_lora_dropout"]),
            )
        print(f"Quality-aware LoRA layers inserted: {replaced}")
        if self.uses_timm and CONFIG.get("qpearl_v2_require_swin_for_final", True) and replaced == 0:
            raise RuntimeError("No LoRA layers were inserted into the Swin-B backbone. Do not proceed with final Q-PEARL-v2.")

        feat_dim = int(getattr(self.backbone, "num_features", 512))
        self.proj = nn.Sequential(
            nn.Linear(feat_dim, 512),
            nn.BatchNorm1d(512),
            nn.PReLU(),
            nn.Linear(512, embedding_dim),
        )

        self.low_quality_residual = nn.Sequential(
            nn.Linear(embedding_dim, embedding_dim // 2),
            nn.PReLU(),
            nn.Linear(embedding_dim // 2, embedding_dim),
        )
        self.high_quality_residual = nn.Sequential(
            nn.Linear(embedding_dim, embedding_dim // 2),
            nn.PReLU(),
            nn.Linear(embedding_dim // 2, embedding_dim),
        )

    def forward(self, x: torch.Tensor, quality: Optional[torch.Tensor] = None):
        if quality is None:
            quality = torch.full((x.shape[0],), 0.5, device=x.device, dtype=x.dtype)
        quality = quality.view(-1).clamp(0.0, 1.0)

        qpearl_v2_set_quality_scalar(self.backbone, quality)
        feat = self.backbone(x)
        emb = self.proj(feat)

        q = quality.view(-1, 1)
        low = self.low_quality_residual(emb)
        high = self.high_quality_residual(emb)
        emb = emb + 0.10 * ((1.0 - q) * low + q * high)
        return F.normalize(emb, dim=1)

def qpearl_v2_trainable_parameters(model: nn.Module, head: Optional[nn.Module] = None):
    params = [p for p in model.parameters() if p.requires_grad]
    if head is not None:
        params += list(head.parameters())
    return params

