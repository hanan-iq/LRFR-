        f"Missing required variables: {missing_vars}. "
        "Run Obj1 and the final Obj3 verification evaluation before this cell."
    )

RESULTS_DIR = Path(RESULTS_DIR)
RESULTS_DIR.mkdir(parents=True, exist_ok=True)

# Pre-specified verification preservation margin.
# A final method is considered preserved if it is not worse than the baseline
# by more than 1.0 percentage point under the paired fold-wise test.
NI_MARGIN = 0.01
ALPHA = 0.05

verification_keys = [
    ("LFW-ORG", "LFW_ORG"),
    ("LFW-LR32", "LFW_LR32"),
    ("LFW-LR16", "LFW_LR16"),
    ("XQLFW", "XQLFW_ORG"),
]

# ------------------------------------------------------------
# 2. Helper functions
# ------------------------------------------------------------
def _get_fold_accs(result_container, key, label):
    if key not in result_container:
        raise KeyError(f"{label} is missing benchmark key: {key}")

    obj = result_container[key]

    if not isinstance(obj, dict):
        raise TypeError(f"{label}[{key}] must be a dict, got {type(obj)}")

    if "fold_accs" not in obj:
        raise KeyError(
            f"{label}[{key}] does not contain 'fold_accs'. "
            "The verification evaluation must save fold-wise accuracies."
        )

    arr = np.asarray(obj["fold_accs"], dtype=np.float64)

    if arr.ndim != 1:
        raise ValueError(f"{label}[{key}]['fold_accs'] must be 1-D, got shape {arr.shape}")

    if len(arr) < 2:
        raise ValueError(f"{label}[{key}]['fold_accs'] must contain at least two folds.")

    if np.any(~np.isfinite(arr)):
        raise ValueError(f"{label}[{key}]['fold_accs'] contains NaN or Inf.")

    return arr


def _format_fold_list(x):
    return [round(float(v * 100.0), 3) for v in x]


def _safe_wilcoxon_noninferiority(diff, margin):
    """
    Paired Wilcoxon non-inferiority test.

    H0: median(final - baseline) <= -margin
    H1: median(final - baseline) >  -margin

    This is implemented as a one-sided Wilcoxon signed-rank test on
    shifted differences: diff + margin > 0.
    """
    shifted = np.asarray(diff, dtype=np.float64) + float(margin)

    if np.allclose(shifted, 0.0):
        return np.nan, 1.0, "all shifted differences are zero"

    try:
        stat, p_value = wilcoxon(
            shifted,
            alternative="greater",
            zero_method="wilcox",
            method="auto",
        )
        return float(stat), float(p_value), "ok"
    except ValueError as e:
        return np.nan, np.nan, f"wilcoxon failed: {repr(e)}"


def _interpretation(p_value):
    if np.isfinite(p_value) and p_value < ALPHA:
        return f"Verification preserved within {NI_MARGIN * 100:.1f} pp margin"
    return f"Preservation not statistically confirmed within {NI_MARGIN * 100:.1f} pp margin"


# ------------------------------------------------------------
# 3. Run benchmark-wise non-inferiority analysis
# ------------------------------------------------------------
rows = []

for paper_name, key in verification_keys:
    base = _get_fold_accs(OBJ1_RESULTS, key, "OBJ1_RESULTS")
    final = _get_fold_accs(OBJ3_RESULTS, key, "OBJ3_RESULTS")

    if len(base) != len(final):
        raise ValueError(
            f"Fold mismatch for {paper_name}: baseline={len(base)}, final={len(final)}"
        )

    diff = final - base

    stat, p_value, status = _safe_wilcoxon_noninferiority(
        diff=diff,
        margin=NI_MARGIN,
