def _safe_metric(metrics, key):
    if not isinstance(metrics, dict):
        return np.nan
    try:
        return float(metrics.get(key, np.nan))
    except Exception:
        return np.nan


def _percent(metrics, key):
    value = _safe_metric(metrics, key)
    if np.isnan(value):
        return np.nan
    return round(100.0 * value, 3)


def _plain(metrics, key):
    value = _safe_metric(metrics, key)
    if np.isnan(value):
        return np.nan
    return round(value, 5)


def _make_result_row(stage, key, role, note):
    metrics = OBJ3_RESULTS.get(key, None)

    if not isinstance(metrics, dict):
        print(f"[SKIP] {stage}, missing key: {key}")
        return None

    return {
        "Stage": stage,
        "Role": role,
        "Rank-1 (%)": _percent(metrics, "rank_1"),
        "Rank-5 (%)": _percent(metrics, "rank_5"),
        "Rank-10 (%)": _percent(metrics, "rank_10"),
        "Rank-20 (%)": _percent(metrics, "rank_20"),
        "mAP (%)": _percent(metrics, "mAP"),
        "AUC": _plain(metrics, "aux_auc"),
        "Top-100 Recall (%)": _percent(metrics, "top100_recall"),
        "Note": note,
    }


def _make_manual_row(stage, role, r1, r5, r20, map_value=np.nan, note=""):
    return {
        "Stage": stage,
        "Role": role,
        "Rank-1 (%)": round(float(r1), 3) if not np.isnan(r1) else np.nan,
        "Rank-5 (%)": round(float(r5), 3) if not np.isnan(r5) else np.nan,
        "Rank-10 (%)": np.nan,
        "Rank-20 (%)": round(float(r20), 3) if not np.isnan(r20) else np.nan,
        "mAP (%)": round(float(map_value), 3) if not np.isnan(map_value) else np.nan,
        "AUC": np.nan,
        "Top-100 Recall (%)": np.nan,
        "Note": note,
    }


def _priority_tuple(row):
    """
    Final selection priority:
    Rank-1, then Rank-5, then Rank-20, then mAP.
    """
    def safe(x):
        try:
            x = float(x)
            if np.isnan(x):
                return -np.inf
            return x
        except Exception:
            return -np.inf

    return (
        safe(row["Rank-1 (%)"]),
        safe(row["Rank-5 (%)"]),
        safe(row["Rank-20 (%)"]),
        safe(row["mAP (%)"]),
    )


