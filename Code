def read_protocol_csv(path: str) -> pd.DataFrame:
    df = pd.read_csv(path, encoding="utf-8-sig")
    if df.shape[1] > 2:
        df = df.iloc[:, :2]
    df.columns = ["person_id", "filename"]
    df["filename"] = df["filename"].astype(str).str.strip().str.strip("'").str.strip('"')
    df["person_id"] = df["person_id"].astype(str)
    return df

def build_filename_index(root: str) -> Dict[str, List[str]]:
    out = defaultdict(list)
    for p in glob.glob(os.path.join(root, "**", "*.jpg"), recursive=True):
        out[os.path.basename(p)].append(p)
    return out

def resolve_paths_from_protocol(df: pd.DataFrame, filename_index: Dict[str, List[str]]) -> Tuple[List[str], np.ndarray]:
    paths, ids = [], []
    misses = 0
    for _, row in df.iterrows():
        fname = row["filename"]
        matches = filename_index.get(fname, [])
        if not matches:
            misses += 1
            continue
        paths.append(matches[0])
        ids.append(row["person_id"])
    if misses:
        print(f"Protocol rows skipped due to missing files: {misses}")
    return paths, np.asarray(ids)

def find_tinyface_protocol_files(eval_root: str) -> Tuple[str, str]:
    gallery_candidates = sorted(glob.glob(os.path.join(eval_root, "*gallery*.csv")))
    probe_candidates = sorted(glob.glob(os.path.join(eval_root, "*probe*.csv")))
    assert gallery_candidates, "TinyFace gallery CSV not found"
    assert probe_candidates, "TinyFace probe CSV not found"
    return gallery_candidates[0], probe_candidates[0]

def tinyface_cache_file(stage_name: str) -> Path:
    return RESULTS_DIR / f"tinyface_{stage_name}.npz"

def extract_tinyface_stage(stage_name: str, cache_prefix: str, adapter: Optional[nn.Module]) -> Dict[str, np.ndarray]:
    cache_file = tinyface_cache_file(stage_name)
    if cache_file.exists():
        data = np.load(cache_file, allow_pickle=True)
        print(f"Loaded TinyFace cache for {stage_name}: {cache_file}")
        return {
            "P": data["P"].astype(np.float32),
            "G": data["G"].astype(np.float32),
            "D": data["D"].astype(np.float32),
            "P_ids": data["P_ids"].astype(str),
            "G_ids": data["G_ids"].astype(str),
            "P_q": data["P_q"].astype(np.float32),
            "G_q": data["G_q"].astype(np.float32),
            "D_q": data["D_q"].astype(np.float32),
        }

    gallery_csv, probe_csv = find_tinyface_protocol_files(TINYFACE_EVAL_ROOT)
    idx = build_filename_index(TINYFACE_TEST_ROOT)
    df_g = read_protocol_csv(gallery_csv)
    df_p = read_protocol_csv(probe_csv)

    g_paths, g_ids = resolve_paths_from_protocol(df_g, idx)
    p_paths, p_ids = resolve_paths_from_protocol(df_p, idx)

    distractor_root = os.path.join(TINYFACE_TEST_ROOT, "Gallery_Distractor")
    d_paths = []
    if os.path.isdir(distractor_root):
        d_paths = sorted(glob.glob(os.path.join(distractor_root, "*.jpg")))
        if CONFIG["tinyface_max_distractors"] is not None:
            d_paths = d_paths[: int(CONFIG["tinyface_max_distractors"])]

    print(f"TinyFace {stage_name}: probes={len(p_paths):,}, gallery_match={len(g_paths):,}, distractors={len(d_paths):,}")

    P = extract_embeddings_from_paths(p_paths, lr_size=None, stage=f"{cache_prefix}_probe", adapter=adapter, use_flip=True)
    G = extract_embeddings_from_paths(g_paths, lr_size=None, stage=f"{cache_prefix}_gallery", adapter=adapter, use_flip=True)
    P_q = get_qualities_for_paths(p_paths, lr_size=None, stage=f"{cache_prefix}_probe")
    G_q = get_qualities_for_paths(g_paths, lr_size=None, stage=f"{cache_prefix}_gallery")
    if d_paths:
        D = extract_embeddings_from_paths(d_paths, lr_size=None, stage=f"{cache_prefix}_distractor", adapter=adapter, use_flip=True)
        D_q = get_qualities_for_paths(d_paths, lr_size=None, stage=f"{cache_prefix}_distractor")
    else:
        D = np.zeros((0, 512), dtype=np.float32)
        D_q = np.zeros((0,), dtype=np.float32)

    np.savez_compressed(cache_file, P=P, G=G, D=D, P_ids=p_ids, G_ids=g_ids, P_q=P_q, G_q=G_q, D_q=D_q)
    print(f"Saved TinyFace cache for {stage_name}: {cache_file}")
    return {"P": P, "G": G, "D": D, "P_ids": p_ids, "G_ids": g_ids, "P_q": P_q, "G_q": G_q, "D_q": D_q}

def evaluate_identification_chunked(
    feats_p: np.ndarray,
    ids_p: np.ndarray,
    gallery_blocks: List[Tuple[np.ndarray, np.ndarray]],
    ranks: Tuple[int, ...] = (1, 5, 20),
    probe_batch: int = CONFIG["tinyface_probe_batch"],
    aux_neg_per_probe: int = CONFIG["tinyface_aux_neg_per_probe"],
    seed: int = SEED,
) -> Dict[str, float]:
    rng = np.random.default_rng(seed)
    ranks = tuple(sorted(ranks))
    max_rank = max(ranks)

    P = l2n_rows(feats_p)
    gallery_blocks = [(l2n_rows(gf), np.asarray(gi)) for gf, gi in gallery_blocks if len(gf) > 0]

    hits = {r: 0 for r in ranks}
    pos_scores, neg_scores = [], []

    for start in tqdm(range(0, len(P), probe_batch), desc="TinyFace eval", leave=False):
        P_chunk = P[start:start + probe_batch]
        ids_chunk = np.asarray(ids_p[start:start + probe_batch])

        top_scores = np.full((len(P_chunk), max_rank), -np.inf, dtype=np.float32)
        top_ids = np.full((len(P_chunk), max_rank), "__none__", dtype=object)

        best_pos = np.full(len(P_chunk), -np.inf, dtype=np.float32)
        sampled_negs = [[] for _ in range(len(P_chunk))]

        for G_block, G_ids in gallery_blocks:
            sims = np.dot(P_chunk, G_block.T).astype(np.float32)
            blk_k = min(max_rank, sims.shape[1])

            blk_top_idx = np.argpartition(-sims, kth=blk_k - 1, axis=1)[:, :blk_k]
            blk_top_scores = np.take_along_axis(sims, blk_top_idx, axis=1)
            blk_top_ids = np.asarray(G_ids, dtype=object)[blk_top_idx]

            if blk_k < max_rank:
                pad_scores = np.full((len(P_chunk), max_rank - blk_k), -np.inf, dtype=np.float32)
                pad_ids = np.full((len(P_chunk), max_rank - blk_k), "__none__", dtype=object)
                blk_top_scores = np.concatenate([blk_top_scores, pad_scores], axis=1)
                blk_top_ids = np.concatenate([blk_top_ids, pad_ids], axis=1)

            merged_scores = np.concatenate([top_scores, blk_top_scores], axis=1)
            merged_ids = np.concatenate([top_ids, blk_top_ids], axis=1)

            order = np.argpartition(-merged_scores, kth=max_rank - 1, axis=1)[:, :max_rank]
            top_scores = np.take_along_axis(merged_scores, order, axis=1)
            top_ids = np.take_along_axis(merged_ids, order, axis=1)
            sort2 = np.argsort(-top_scores, axis=1)
            top_scores = np.take_along_axis(top_scores, sort2, axis=1)
            top_ids = np.take_along_axis(top_ids, sort2, axis=1)

            G_ids_arr = np.asarray(G_ids)
            for i, true_id in enumerate(ids_chunk):
                pos_mask = (G_ids_arr == true_id)
                if np.any(pos_mask):
                    best_pos[i] = max(best_pos[i], float(sims[i, pos_mask].max()))

                neg_mask = (G_ids_arr != true_id)
                neg_idx = np.where(neg_mask)[0]
                if len(neg_idx) > 0:
                    sample_size = min(max(1, aux_neg_per_probe // max(1, len(gallery_blocks))), len(neg_idx))
                    take = rng.choice(neg_idx, size=sample_size, replace=False)
                    sampled_negs[i].extend(sims[i, take].astype(np.float32).tolist())

        for i, true_id in enumerate(ids_chunk):
            pred_ids = top_ids[i]
            for r in ranks:
                if true_id in pred_ids[:r]:
                    hits[r] += 1
            if math.isfinite(float(best_pos[i])):
                pos_scores.append(float(best_pos[i]))
            neg_scores.extend(sampled_negs[i])

    n_probe = len(P)
    out = {f"rank_{r}": float(hits[r] / n_probe) for r in ranks}

    if len(pos_scores) > 0 and len(neg_scores) > 0:
        y_true = np.concatenate([np.ones(len(pos_scores), dtype=np.int32), np.zeros(len(neg_scores), dtype=np.int32)])
        y_score = np.concatenate([np.asarray(pos_scores, dtype=np.float32), np.asarray(neg_scores, dtype=np.float32)])
        fpr, tpr, _ = roc_curve(y_true, y_score)
        aux_auc = float(auc(fpr, tpr))
        fnr = 1.0 - tpr
        aux_eer = float(fpr[np.nanargmin(np.abs(fpr - fnr))])
    else:
        aux_auc = float("nan")
        aux_eer = float("nan")

    out["aux_auc"] = aux_auc
    out["aux_eer"] = aux_eer
    return out

def center_by_gallery_distribution(P: np.ndarray, G: np.ndarray, D: Optional[np.ndarray] = None):
    total = G.sum(axis=0, keepdims=True).astype(np.float32)
    n = float(len(G))
    if D is not None and len(D) > 0:
        total += D.sum(axis=0, keepdims=True).astype(np.float32)
        n += float(len(D))
    mu = total / max(n, 1.0)
    P_c = P - mu
    G_c = G - mu
    D_c = None if D is None or len(D) == 0 else D - mu
    return P_c.astype(np.float32), G_c.astype(np.float32), None if D_c is None else D_c.astype(np.float32), mu.astype(np.float32)

def dba_gallery(G_match: np.ndarray, topk: int, alpha: float) -> np.ndarray:
    X = l2n_rows(G_match)
    sims = np.dot(X, X.T)
    idx = np.argsort(-sims, axis=1)[:, 1:topk + 1]
    w = np.array([1.0 / (i + 1) for i in range(topk)], dtype=np.float32)
    X_new = X.copy()
    for i in range(len(X)):
        neigh = X[idx[i]]
        X_new[i] += alpha * (neigh * w[:, None]).sum(axis=0) / w.sum()
    return l2n_rows(X_new)

def build_identity_prototypes(
    G_match: np.ndarray,
    G_ids: np.ndarray,
    G_quality: Optional[np.ndarray] = None,
) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """Build identity prototypes with DPRG reliability scores.

    Returns (Proto, Proto_ids, Proto_rel) where Proto_rel[i] is the
    reliability score for the i-th prototype identity.
    """
    w_c = CONFIG.get("obj3_proto_rel_compactness_w", 0.55)
    w_q = CONFIG.get("obj3_proto_rel_quality_w", 0.30)
    w_s = CONFIG.get("obj3_proto_rel_support_w", 0.15)
    top_frac = CONFIG.get("obj3_proto_core_top_fraction", 0.40)

    protos, proto_ids, proto_rels = [], [], []
    Gn = l2n_rows(G_match)
    uniq = pd.unique(pd.Series(G_ids))

    for pid in uniq:
        mask = (G_ids == pid)
        group = Gn[mask]
        n_y = int(mask.sum())

        # Mean prototype
        p_mean = l2n_rows(group.mean(axis=0, keepdims=True))[0]

        # Compactness: mean cosine to p_mean
        if n_y >= 2:
            c_y = float(np.dot(group, p_mean).mean())
        else:
            c_y = 1.0

        # Gallery quality (nan-safe median)
        if G_quality is not None and len(G_quality) == len(G_ids):
            q_raw = np.asarray(G_quality[mask], dtype=np.float64)
            q_y = float(np.nanmedian(q_raw)) if np.any(np.isfinite(q_raw)) else 0.5
            q_y = float(np.nan_to_num(q_y, nan=0.5, posinf=1.0, neginf=0.0))
        else:
            q_y = 0.5

        # Support factor
        s_y = min(1.0, float(np.log1p(n_y) / np.log(5.0)))

        # Reliability score (nan-safe)
        rho = float(np.clip(np.nan_to_num(w_c * c_y + w_q * q_y + w_s * s_y, nan=0.5), 0.0, 1.0))

        # Core prototype: top-m samples ranked by 0.7*cos(sample,p_mean)+0.3*quality
        m = max(1, int(np.ceil(top_frac * n_y)))
        if G_quality is not None and len(G_quality) == len(G_ids):
            q_group = np.nan_to_num(np.asarray(G_quality[mask], dtype=np.float32), nan=0.5, posinf=1.0, neginf=0.0)
        else:
            q_group = np.full(n_y, 0.5, dtype=np.float32)
        scores = 0.7 * np.dot(group, p_mean) + 0.3 * q_group
        top_idx = np.argsort(-scores)[:m]
        p_core = l2n_rows(group[top_idx].mean(axis=0, keepdims=True))[0]

        # Final prototype: blend by reliability
        p_final = l2n_rows((rho * p_mean + (1.0 - rho) * p_core).reshape(1, -1))[0]

        protos.append(p_final)
        proto_ids.append(pid)
        proto_rels.append(rho)

    return (
        np.stack(protos).astype(np.float32),
        np.asarray(proto_ids),
        np.asarray(proto_rels, dtype=np.float32),
    )

def images_per_identity_stats(ids: np.ndarray) -> Dict[str, float]:
    vc = pd.Series(ids).value_counts()
    return {
        "num_identities": int(vc.shape[0]),
        "num_images": int(vc.sum()),
        "mean_images_per_id": float(vc.mean()),
        "median_images_per_id": float(vc.median()),
        "max_images_per_id": int(vc.max()),
    }

def softmax_np(x: np.ndarray, tau: float = 0.07) -> np.ndarray:
    z = x / max(tau, 1e-6)
    z = z - z.max(axis=1, keepdims=True)
    e = np.exp(z)
    return e / (e.sum(axis=1, keepdims=True) + 1e-10)

def prototype_guided_calibration_v3(
    P: np.ndarray,
    G_ref: np.ndarray,
    G_ids: np.ndarray,
    proto_feats: np.ndarray,
    proto_ids: np.ndarray,
    probe_quality: Optional[np.ndarray] = None,
    topk_proto: int = CONFIG["obj3_proto_topk"],
    competitor_k: int = CONFIG["obj3_competitor_k"],
    competitor_gamma: float = CONFIG["obj3_competitor_gamma"],
    max_alpha: float = CONFIG["obj3_max_alpha"],
    margin_lo: float = CONFIG["obj3_margin_lo"],
    margin_hi: float = CONFIG["obj3_margin_hi"],
    disagree_scale: float = CONFIG["obj3_disagree_scale"],
    vote_topm: int = CONFIG["obj3_gallery_vote_topm"],
    tau: float = CONFIG["obj3_softmax_tau"],
    top1_sim_lo: float = CONFIG["obj3_top1_sim_lo"],
    local_sameid_topm: int = CONFIG["obj3_local_sameid_topm"],
    target_proto_blend: float = CONFIG["obj3_target_proto_blend"],
    batch_size: int = 256,
):
    Q = l2n_rows(P)
    G = l2n_rows(G_ref)
    G_ids = np.asarray(G_ids)
    Proto = l2n_rows(proto_feats)
    proto_ids = np.asarray(proto_ids)

    if probe_quality is None or len(probe_quality) != len(Q):
        probe_quality = np.ones(len(Q), dtype=np.float32)
    else:
        probe_quality = np.asarray(probe_quality, dtype=np.float32)

    q_lo = float(np.percentile(probe_quality, 25))
    q_hi = float(np.percentile(probe_quality, 75))

    id_to_gidx = defaultdict(list)
    for i, pid in enumerate(G_ids):
        id_to_gidx[str(pid)].append(i)

    out = np.zeros_like(Q, dtype=np.float32)
    strengths, margins, agreements, top1_sims, entropies, quality_gates = [], [], [], [], [], []

    total_take = max(2, topk_proto + competitor_k)
    for start in tqdm(range(0, len(Q), batch_size), desc="Obj3 probe calibration", leave=False):
        q = Q[start:start + batch_size]
        q_quality = probe_quality[start:start + batch_size]
        sims_proto = np.dot(q, Proto.T).astype(np.float32)

        take = min(total_take, sims_proto.shape[1])
        idx = np.argpartition(-sims_proto, kth=take - 1, axis=1)[:, :take]
        scr = np.take_along_axis(sims_proto, idx, axis=1)
        ord2 = np.argsort(-scr, axis=1)
        idx = np.take_along_axis(idx, ord2, axis=1)
        scr = np.take_along_axis(scr, ord2, axis=1)

        pos_k = min(topk_proto, idx.shape[1])
        pos_idx = idx[:, :pos_k]
        pos_scr = scr[:, :pos_k]
        pos_w = softmax_np(pos_scr, tau=tau)
        pos_agg = (Proto[pos_idx] * pos_w[:, :, None]).sum(axis=1)

        if idx.shape[1] > pos_k:
            neg_idx = idx[:, pos_k:pos_k + competitor_k]
            neg_scr = scr[:, pos_k:pos_k + competitor_k]
            if neg_idx.shape[1] > 0:
                neg_w = softmax_np(neg_scr, tau=tau)
                neg_agg = (Proto[neg_idx] * neg_w[:, :, None]).sum(axis=1)
            else:
                neg_agg = np.zeros_like(pos_agg)
        else:
            neg_agg = np.zeros_like(pos_agg)

        top1_sim = scr[:, 0]
        margin = scr[:, 0] - scr[:, 1] if scr.shape[1] > 1 else scr[:, 0]
        uncertainty = np.clip((margin_hi - margin) / (margin_hi - margin_lo + 1e-10), 0.0, 1.0)
        sim_gate = np.clip((top1_sim - top1_sim_lo) / (1.0 - top1_sim_lo + 1e-10), 0.0, 1.0)

        quality_gate = np.clip((q_hi - q_quality) / (q_hi - q_lo + 1e-10), 0.0, 1.0)

        sims_gallery = np.dot(q, G.T).astype(np.float32)
        gm = min(vote_topm, sims_gallery.shape[1])
        gidx = np.argpartition(-sims_gallery, kth=gm - 1, axis=1)[:, :gm]
        gscr = np.take_along_axis(sims_gallery, gidx, axis=1)
        gord = np.argsort(-gscr, axis=1)
        gidx = np.take_along_axis(gidx, gord, axis=1)
        top_gallery_ids = G_ids[gidx]

        local_sameid = np.zeros_like(pos_agg)
        top_proto_ids = proto_ids[pos_idx[:, 0]]
        agree = []
        entropy = -(pos_w * np.log(pos_w + 1e-10)).sum(axis=1) / np.log(max(pos_w.shape[1], 2))

        for i in range(len(q)):
            pid = str(top_proto_ids[i])
            row_ids = top_gallery_ids[i]
            agree.append(float(pid in row_ids[:max(1, gm // 2 + 1)]))
            same_idx = id_to_gidx.get(pid, [])
            if same_idx:
                same_idx = np.asarray(same_idx, dtype=np.int32)
                sims_same = sims_gallery[i, same_idx]
                take_same = min(local_sameid_topm, len(same_idx))
                if take_same > 0:
                    top_same_local = np.argpartition(-sims_same, kth=take_same - 1)[:take_same]
                    local = G[same_idx[top_same_local]].mean(axis=0, keepdims=True)
                    local_sameid[i] = l2n_rows(local)[0]

        agree = np.asarray(agree, dtype=np.float32)
        agreement_gate = np.where(agree > 0.0, 1.0, disagree_scale).astype(np.float32)
        entropy_gate = 0.5 + 0.5 * entropy.astype(np.float32)

        target = l2n_rows(target_proto_blend * pos_agg + (1.0 - target_proto_blend) * local_sameid)
        alpha = max_alpha * uncertainty * sim_gate * agreement_gate * entropy_gate * (0.50 + 0.50 * quality_gate)

        q_new = l2n_rows(q + alpha[:, None] * (target - competitor_gamma * neg_agg))
        out[start:start + batch_size] = q_new.astype(np.float32)

        strengths.extend(alpha.astype(np.float32).tolist())
        margins.extend(margin.astype(np.float32).tolist())
        agreements.extend(agree.astype(np.float32).tolist())
        top1_sims.extend(top1_sim.astype(np.float32).tolist())
        entropies.extend(entropy.astype(np.float32).tolist())
        quality_gates.extend(quality_gate.astype(np.float32).tolist())

    stats = {
        "strength_mean": float(np.mean(strengths)) if strengths else 0.0,
        "strength_std": float(np.std(strengths)) if strengths else 0.0,
        "strength_max": float(np.max(strengths)) if strengths else 0.0,
        "margin_mean": float(np.mean(margins)) if margins else 0.0,
        "agreement_rate": float(np.mean(agreements)) if agreements else 0.0,
        "top1_sim_mean": float(np.mean(top1_sims)) if top1_sims else 0.0,
        "entropy_mean": float(np.mean(entropies)) if entropies else 0.0,
        "quality_gate_mean": float(np.mean(quality_gates)) if quality_gates else 0.0,
    }
    diag = {
        "strength": np.asarray(strengths, dtype=np.float32),
        "margin": np.asarray(margins, dtype=np.float32),
        "agree": np.asarray(agreements, dtype=np.float32),
        "top1_sim": np.asarray(top1_sims, dtype=np.float32),
        "entropy": np.asarray(entropies, dtype=np.float32),
        "quality_gate": np.asarray(quality_gates, dtype=np.float32),
    }
    return out.astype(np.float32), stats, diag

def evaluate_tinyface_obj3_rerank(
    P: np.ndarray,
    P_ids: np.ndarray,
    G: np.ndarray,
    G_ids: np.ndarray,
    Proto: np.ndarray,
    Proto_ids: np.ndarray,
    D: Optional[np.ndarray],
    ranks: Tuple[int, ...] = (1, 5, 20),
    probe_batch: int = CONFIG["tinyface_probe_batch"],
    candidate_gallery_k: int = CONFIG["obj3_tinyface_candidate_gallery"],
    candidate_distractor_k: int = CONFIG["obj3_tinyface_candidate_distractor"],
    proto_weight: float = CONFIG["obj3_tinyface_proto_weight"],
    id_weight: float = CONFIG["obj3_tinyface_id_weight"],
    distractor_penalty: float = CONFIG["obj3_tinyface_distractor_penalty"],
) -> Dict[str, float]:
    rng = np.random.default_rng(SEED)
    P = l2n_rows(P)
    G = l2n_rows(G)
    Proto = l2n_rows(Proto)
    D = np.zeros((0, G.shape[1]), dtype=np.float32) if D is None else l2n_rows(D)

    id_to_proto = {str(pid): i for i, pid in enumerate(Proto_ids)}
    ranks = tuple(sorted(ranks))
    max_rank = max(ranks)

    hits = {r: 0 for r in ranks}
    pos_scores, neg_scores = [], []

    for start in tqdm(range(0, len(P), probe_batch), desc="Obj3 TinyFace rerank", leave=False):
        q = P[start:start + probe_batch]
        ids_chunk = np.asarray(P_ids[start:start + probe_batch])

        sims_g = np.dot(q, G.T).astype(np.float32)
        sims_p = np.dot(q, Proto.T).astype(np.float32)
        sims_d = np.dot(q, D.T).astype(np.float32) if len(D) > 0 else np.zeros((len(q), 0), dtype=np.float32)

        kg = min(candidate_gallery_k, sims_g.shape[1])
        kd = min(candidate_distractor_k, sims_d.shape[1]) if sims_d.shape[1] > 0 else 0

        topg_idx = np.argpartition(-sims_g, kth=kg - 1, axis=1)[:, :kg]
        topg_scr = np.take_along_axis(sims_g, topg_idx, axis=1)
        gsort = np.argsort(-topg_scr, axis=1)
        topg_idx = np.take_along_axis(topg_idx, gsort, axis=1)
        topg_scr = np.take_along_axis(topg_scr, gsort, axis=1)

        if kd > 0:
            topd_idx = np.argpartition(-sims_d, kth=kd - 1, axis=1)[:, :kd]
            topd_scr = np.take_along_axis(sims_d, topd_idx, axis=1)
            dsort = np.argsort(-topd_scr, axis=1)
            topd_idx = np.take_along_axis(topd_idx, dsort, axis=1)
            topd_scr = np.take_along_axis(topd_scr, dsort, axis=1)
        else:
            topd_scr = np.zeros((len(q), 0), dtype=np.float32)

        for i, true_id in enumerate(ids_chunk):
            cand_idx = topg_idx[i]
            cand_scr = topg_scr[i]
            cand_ids = G_ids[cand_idx]

            id_best = {}
            id_mean = {}
            for pid in pd.unique(pd.Series(cand_ids)):
                mask = (cand_ids == pid)
                vals = cand_scr[mask]
                id_best[str(pid)] = float(vals.max())
                id_mean[str(pid)] = float(vals[: min(3, len(vals))].mean())

            fused_gallery = []
            fused_gallery_ids = []
            for gi, raw in zip(cand_idx, cand_scr):
                pid = str(G_ids[gi])
                pidx = id_to_proto.get(pid, None)
                pscore = float(sims_p[i, pidx]) if pidx is not None else -1.0
                idboost = 0.5 * id_best.get(pid, raw) + 0.5 * id_mean.get(pid, raw)
                fused = float(raw + proto_weight * pscore + id_weight * idboost)
                fused_gallery.append(fused)
                fused_gallery_ids.append(pid)

            fused_d = [float(s - distractor_penalty) for s in topd_scr[i]] if kd > 0 else []
            fused_d_ids = ["-1"] * len(fused_d)

            all_scores = np.asarray(fused_gallery + fused_d, dtype=np.float32)
            all_ids = np.asarray(fused_gallery_ids + fused_d_ids, dtype=object)

            take = min(max_rank, len(all_scores))
            order = np.argpartition(-all_scores, kth=take - 1)[:take]
            order = order[np.argsort(-all_scores[order])]
            pred_ids = all_ids[order]

            for r in ranks:
                if true_id in pred_ids[:r]:
                    hits[r] += 1

            pos_mask = (G_ids == true_id)
            if np.any(pos_mask):
                best_pos = float(sims_g[i, pos_mask].max())
                pos_scores.append(best_pos)

            if len(D) > 0:
                neg_take = min(CONFIG["tinyface_aux_neg_per_probe"], D.shape[0])
                rand_neg = rng.choice(D.shape[0], size=neg_take, replace=False)
                neg_scores.extend(sims_d[i, rand_neg].astype(np.float32).tolist())

    n_probe = len(P)
    out = {f"rank_{r}": float(hits[r] / n_probe) for r in ranks}

    if len(pos_scores) > 0 and len(neg_scores) > 0:
        y_true = np.concatenate([np.ones(len(pos_scores), dtype=np.int32), np.zeros(len(neg_scores), dtype=np.int32)])
        y_score = np.concatenate([np.asarray(pos_scores, dtype=np.float32), np.asarray(neg_scores, dtype=np.float32)])
        fpr, tpr, _ = roc_curve(y_true, y_score)
        aux_auc = float(auc(fpr, tpr))
        fnr = 1.0 - tpr
        aux_eer = float(fpr[np.nanargmin(np.abs(fpr - fnr))])
    else:
        aux_auc = float("nan")
        aux_eer = float("nan")

    out["aux_auc"] = aux_auc
    out["aux_eer"] = aux_eer
    return out

