from torch.utils.data import Dataset, DataLoader

MEM_EMBED_CACHE: Dict[Tuple[str, Optional[int], str], np.ndarray] = {}
MEM_QUAL_CACHE: Dict[Tuple[str, Optional[int], str], float] = {}

def l2n_rows(x: np.ndarray) -> np.ndarray:
    x = np.asarray(x, dtype=np.float32)
    return x / (np.linalg.norm(x, axis=1, keepdims=True) + 1e-10)

def safe_imread(path: str) -> np.ndarray:
    img = cv2.imread(path)
    if img is None:
        raise FileNotFoundError(f"Failed to read image: {path}")
    return img

def maybe_center_crop(img_bgr: np.ndarray) -> np.ndarray:
    h, w = img_bgr.shape[:2]
    if h > 128 and w > 128:
        cy, cx = h // 2, w // 2
        y1, y2 = max(0, cy - 64), min(h, cy + 64)
        x1, x2 = max(0, cx - 64), min(w, cx + 64)
        img_bgr = img_bgr[y1:y2, x1:x2]
    return img_bgr

def degrade_then_restore(img_bgr: np.ndarray, lr_size: Optional[int]) -> np.ndarray:
    if lr_size is None:
        return img_bgr
    small = cv2.resize(img_bgr, (lr_size, lr_size), interpolation=cv2.INTER_LINEAR)
    up = cv2.resize(small, REC_INPUT_SIZE, interpolation=cv2.INTER_CUBIC)
    return up

def prep_bgr(path: str, lr_size: Optional[int] = None) -> np.ndarray:
    img = safe_imread(path)
    img = maybe_center_crop(img)
    img = cv2.resize(img, REC_INPUT_SIZE, interpolation=cv2.INTER_LINEAR)
    img = degrade_then_restore(img, lr_size)
    if img.shape[:2] != REC_INPUT_SIZE[::-1]:
        img = cv2.resize(img, REC_INPUT_SIZE, interpolation=cv2.INTER_LINEAR)
    return img
class ListDataset(Dataset):
    def __init__(self, img_list: List[str], image_size: int = 112, lr_size: Optional[int] = None):
        self.img_list = list(img_list)
        self.image_size = image_size
        self.lr_size = lr_size
        self.transform = transforms.Compose([
            transforms.ToTensor(),
            transforms.Resize((image_size, image_size), interpolation=InterpolationMode.BICUBIC),
            transforms.Normalize([0.5] * 3, [0.5] * 3),
        ])

    def __len__(self):
        return len(self.img_list)

    def __getitem__(self, idx):
        img = prep_bgr(self.img_list[idx], lr_size=self.lr_size)
        img = cv2.cvtColor(img[:, :, :3], cv2.COLOR_BGR2RGB)
        return self.transform(Image.fromarray(img)), idx

class GenericResidualAdapter(nn.Module):
    def __init__(self, dim: int = 512, hidden_dim: int = 512):
        super().__init__()
        self.fc1 = nn.Linear(dim, hidden_dim)
        self.act = nn.GELU()
        self.fc2 = nn.Linear(hidden_dim, dim)
        self.scale = nn.Parameter(torch.tensor(0.10))

    def forward(self, x):
        return x + self.scale * self.fc2(self.act(self.fc1(x)))

def try_load_obj2_adapter(ckpt_path: Optional[str]) -> Optional[nn.Module]:
    if ckpt_path is None or not os.path.exists(ckpt_path):
        print("Obj2 adapter not provided. Obj2 will use score/feature stabilization only.")
        return None

    ckpt = torch.load(ckpt_path, map_location=DEVICE)
    if isinstance(ckpt, dict):
        state = ckpt.get("state_dict", ckpt.get("model_state", ckpt.get("adapter_state_dict", ckpt)))
    else:
        print("Unsupported adapter checkpoint object, skipping Obj2 adapter.")
        return None

    adapter = GenericResidualAdapter(dim=512, hidden_dim=512).to(DEVICE)
    try:
        missing, unexpected = adapter.load_state_dict(state, strict=False)
        print(f"Obj2 adapter loaded with missing={len(missing)}, unexpected={len(unexpected)}")
        adapter.eval()
        return adapter
    except Exception as e:
        print(f"Failed to load adapter checkpoint safely: {e}")
        return None

OBJ2_ADAPTER = try_load_obj2_adapter(OBJ2_ADAPTER_CKPT)

@torch.no_grad()
def apply_feature_adapter_np(feats: np.ndarray, adapter: Optional[nn.Module], batch_size: int = 4096) -> np.ndarray:
    feats = np.asarray(feats, dtype=np.float32)
    if adapter is None:
        return l2n_rows(feats)
    adapter.eval()
    outs = []
    for start in range(0, len(feats), batch_size):
        x = torch.from_numpy(feats[start:start + batch_size]).to(DEVICE)
        y = adapter(x).detach().cpu().numpy()
        outs.append(y)
    return l2n_rows(np.concatenate(outs, axis=0))

@torch.no_grad()
def infer_r100(model: nn.Module, dataloader: DataLoader, device: str = "cuda", flip_test: bool = True) -> Tuple[np.ndarray, np.ndarray]:
    model.eval()
    feats, norms = [], []
    for images, _ in tqdm(dataloader, leave=False):
        images = images.to(device)
        out = model(images)
        if isinstance(out, tuple):
            feat, norm = out
        else:
            norm = torch.norm(out, 2, 1, True)
            feat = torch.div(out, norm)
        if flip_test:
            out2 = model(torch.flip(images, dims=[3]))
            if isinstance(out2, tuple):
                feat2, norm2 = out2
            else:
                norm2 = torch.norm(out2, 2, 1, True)
                feat2 = torch.div(out2, norm2)
            pre = torch.stack([feat * norm, feat2 * norm2], dim=0).sum(dim=0)
            fused_norm = torch.norm(pre, 2, 1, True)
            feat = torch.div(pre, fused_norm + 1e-10)
            norm = fused_norm
        feats.append(feat.detach().cpu().numpy())
        norms.append(norm.detach().cpu().numpy())
    return np.concatenate(feats, axis=0), np.concatenate(norms, axis=0)

def extract_embeddings_from_paths(
    paths: List[str],
    lr_size: Optional[int],
    stage: str,
    use_flip: bool = True,
    adapter: Optional[nn.Module] = None,
    batch_size: int = CONFIG["embed_batch_size"],
) -> np.ndarray:
    if len(paths) == 0:
        return np.zeros((0, 512), dtype=np.float32)

    missing_paths = [p for p in paths if (p, lr_size, stage) not in MEM_EMBED_CACHE]
    if missing_paths:
        uniq_missing = list(dict.fromkeys(missing_paths))
        print(f"[{stage}] Extracting {len(uniq_missing):,} uncached images (lr={lr_size}) ...")

        dl = DataLoader(
            ListDataset(uniq_missing, image_size=CONFIG["img_size"], lr_size=lr_size),
            batch_size=int(batch_size),
            shuffle=False,
            num_workers=CONFIG.get("qpearl_num_workers", 2),
            drop_last=False,
            pin_memory=(str(DEVICE).lower() == "cuda"),
        )
        feats, norms = infer_r100(rec_model, dl, device=DEVICE, flip_test=use_flip)

        for p, feat, normv in zip(uniq_missing, feats, norms):
            MEM_EMBED_CACHE[(p, lr_size, stage)] = feat.astype(np.float32)
            MEM_QUAL_CACHE[(p, lr_size, stage)] = float(np.clip(normv.reshape(-1)[0] / 30.0, 0.0, 1.0))

    feats = np.stack([MEM_EMBED_CACHE[(p, lr_size, stage)] for p in paths]).astype(np.float32)
    feats = apply_feature_adapter_np(feats, adapter)
    return feats

def get_qualities_for_paths(paths: List[str], lr_size: Optional[int], stage: str) -> np.ndarray:
    quals = []
    for p in paths:
        key = (p, lr_size, stage)
        if key not in MEM_QUAL_CACHE:
            img = prep_bgr(p, lr_size=lr_size)
            quals.append(image_quality_score(img))
        else:
            quals.append(MEM_QUAL_CACHE[key])
    return np.asarray(quals, dtype=np.float32)

def image_quality_score(img_bgr: np.ndarray) -> float:
    gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY).astype(np.float32)
    sharp = float(np.var(cv2.Laplacian(gray, cv2.CV_32F)))
    contrast = float(gray.std())
    return float(np.clip(0.5 * np.tanh(sharp / 150.0) + 0.5 * np.tanh(contrast / 64.0), 0.0, 1.0))


