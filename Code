    fpr, tpr, _ = roc_curve(labels.astype(np.int32), all_scores)
    roc_auc = float(auc(fpr, tpr))
    roc_path = save_roc_artifact("Obj2", name, fpr, tpr)
    return {
        "accuracy": float(np.mean(fold_accs)),
        "std": float(np.std(fold_accs)),
        "fold_accs": [float(x) for x in fold_accs],
        "fold_thresholds": [float(x) for x in fold_thresholds],
        "n_folds": int(len(fold_accs)),
        "AUC": roc_auc,
        "threshold_mean": float(np.mean(fold_thresholds)),
        "threshold_std": float(np.std(fold_thresholds)),
        "n_pairs": int(len(valid)),
        "roc_path": roc_path,
    }

def evaluate_pairs_cv_obj3plus(
    root: str,
    pairs_path: str,
    lr_size: Optional[int],
    cache_stage: str,
    adapter: Optional[nn.Module],
    name: str,
    return_diag: bool = False,
) -> Dict[str, float]:
    valid, uniq_paths, path_to_emb, path_to_q = prepare_pairs_embeddings(root, pairs_path, lr_size, cache_stage, adapter)
    labels = np.asarray([bool(s) for _, _, s in valid], dtype=bool)
    folds = assign_folds(len(valid), n_folds=CONFIG["pair_folds"])
    dataset_key = score_dataset_key(root, lr_size)
    base_as_w = obj2_asnorm_weight(dataset_key)

    all_scores = np.zeros(len(valid), dtype=np.float32)
    fold_accs, fold_thresholds = [], []
    all_diag = defaultdict(list)

    for fold in range(CONFIG["pair_folds"]):
        train_idx = np.where(folds != fold)[0]
        test_idx = np.where(folds == fold)[0]
        cohort_paths = list(dict.fromkeys([p for i in train_idx for p in (valid[i][0], valid[i][1])]))
        stats = compute_asnorm_stats_plus(uniq_paths, cohort_paths, path_to_emb, topk=CONFIG["pair_asnorm_topk"])

        train_pair_q = np.asarray([min(path_to_q[valid[i][0]], path_to_q[valid[i][1]]) for i in train_idx], dtype=np.float32)
        gaps = []
        ents = []
        for p in cohort_paths:
            _, _, t1, t2, ent = stats[p]
            gaps.append(max(0.0, t1 - t2))
            ents.append(ent)
        q_lo = float(np.percentile(train_pair_q, CONFIG["obj3_verif_margin_q_lo"]))
        q_hi = float(np.percentile(train_pair_q, CONFIG["obj3_verif_margin_q_hi"]))
        q_mu = float(train_pair_q.mean())
        q_sd = float(train_pair_q.std() + 1e-6)
        gap_lo = float(np.percentile(np.asarray(gaps, dtype=np.float32), CONFIG["obj3_verif_margin_q_lo"]))
        gap_hi = float(np.percentile(np.asarray(gaps, dtype=np.float32), CONFIG["obj3_verif_margin_q_hi"]))

        train_scores = []
        for i in train_idx:
            sc, _ = pair_score_from_stats_obj3(valid[i][0], valid[i][1], path_to_emb, path_to_q, stats, base_as_w, q_lo, q_hi, gap_lo, gap_hi, q_mu, q_sd)
            train_scores.append(sc)
        train_scores = np.asarray(train_scores, dtype=np.float32)

        test_scores = []
        for i in test_idx:
            sc, dg = pair_score_from_stats_obj3(valid[i][0], valid[i][1], path_to_emb, path_to_q, stats, base_as_w, q_lo, q_hi, gap_lo, gap_hi, q_mu, q_sd)
            test_scores.append(sc)
            if return_diag:
                for k, v in dg.items():
                    all_diag[k].append(float(v))
        test_scores = np.asarray(test_scores, dtype=np.float32)

        all_scores[test_idx] = test_scores
        thr = best_threshold_from_train(train_scores, labels[train_idx])
        acc = float(((test_scores > thr) == labels[test_idx]).mean())
        fold_accs.append(acc)
        fold_thresholds.append(thr)

    fpr, tpr, _ = roc_curve(labels.astype(np.int32), all_scores)
    roc_auc = float(auc(fpr, tpr))
    roc_path = save_roc_artifact("Obj3", name, fpr, tpr)

    out = {
        "accuracy": float(np.mean(fold_accs)),
        "std": float(np.std(fold_accs)),
        "fold_accs": [float(x) for x in fold_accs],
        "fold_thresholds": [float(x) for x in fold_thresholds],
        "n_folds": int(len(fold_accs)),
        "AUC": roc_auc,
        "threshold_mean": float(np.mean(fold_thresholds)),
        "threshold_std": float(np.std(fold_thresholds)),
        "n_pairs": int(len(valid)),
        "roc_path": roc_path,
    }
    if return_diag:
        out["diag"] = {k: [float(x) for x in v] for k, v in all_diag.items()}
    return out

def prototype_guided_calibration_v4(
    P: np.ndarray,
    G_ref: np.ndarray,
    G_ids: np.ndarray,
    proto_feats: np.ndarray,
    proto_ids: np.ndarray,
    probe_quality: Optional[np.ndarray] = None,
    topk_proto: int = CONFIG["obj3_proto_topk"],
    competitor_k: int = CONFIG["obj3_competitor_k"],
    competitor_gamma: float = CONFIG["obj3_competitor_gamma"],
    max_alpha: float = CONFIG["obj3_max_alpha"],
    margin_lo: float = CONFIG["obj3_margin_lo"],
    margin_hi: float = CONFIG["obj3_margin_hi"],
    disagree_scale: float = CONFIG["obj3_disagree_scale"],
    vote_topm: int = CONFIG["obj3_gallery_vote_topm"],
    tau: float = CONFIG["obj3_softmax_tau"],
    top1_sim_lo: float = CONFIG["obj3_top1_sim_lo"],
    local_sameid_topm: int = CONFIG["obj3_local_sameid_topm"],
    target_proto_blend: float = CONFIG["obj3_target_proto_blend"],
    batch_size: int = 256,
    return_diag: bool = True,
):
    Q = l2n_rows(P)
    G = l2n_rows(G_ref)
    G_ids = np.asarray(G_ids)
    Proto = l2n_rows(proto_feats)
    proto_ids = np.asarray(proto_ids)

    if probe_quality is None or len(probe_quality) != len(Q):
        probe_quality = np.ones(len(Q), dtype=np.float32)
    else:
        probe_quality = np.asarray(probe_quality, dtype=np.float32)

    q_lo = float(np.percentile(probe_quality, 25))
    q_hi = float(np.percentile(probe_quality, 75))
    id_to_gidx = defaultdict(list)
    for i, pid in enumerate(G_ids):
        id_to_gidx[str(pid)].append(i)

    out = np.zeros_like(Q, dtype=np.float32)
    strengths, margins, agreements, top1_sims = [], [], [], []
    entropies, quality_gates, ambiguity_gates, consistency_gates = [], [], [], []
    local_supports = []

    total_take = max(2, topk_proto + competitor_k)
    for start in tqdm(range(0, len(Q), batch_size), desc="Obj3+ probe calibration", leave=False):
        q = Q[start:start + batch_size]
        q_quality = probe_quality[start:start + batch_size]
        sims_proto = np.dot(q, Proto.T).astype(np.float32)

        take = min(total_take, sims_proto.shape[1])
        idx = np.argpartition(-sims_proto, kth=take - 1, axis=1)[:, :take]
        scr = np.take_along_axis(sims_proto, idx, axis=1)
        ord2 = np.argsort(-scr, axis=1)
        idx = np.take_along_axis(idx, ord2, axis=1)
        scr = np.take_along_axis(scr, ord2, axis=1)

        pos_k = min(topk_proto, idx.shape[1])
        pos_idx = idx[:, :pos_k]
        pos_scr = scr[:, :pos_k]
        pos_w = softmax_np(pos_scr, tau=tau)
        pos_agg = (Proto[pos_idx] * pos_w[:, :, None]).sum(axis=1)

        if idx.shape[1] > pos_k:
            neg_idx = idx[:, pos_k:pos_k + competitor_k]
            neg_scr = scr[:, pos_k:pos_k + competitor_k]
            neg_w = softmax_np(neg_scr, tau=tau) if neg_idx.shape[1] > 0 else np.zeros((len(q), 0), dtype=np.float32)
            neg_agg = (Proto[neg_idx] * neg_w[:, :, None]).sum(axis=1) if neg_idx.shape[1] > 0 else np.zeros_like(pos_agg)
        else:
            neg_agg = np.zeros_like(pos_agg)

        top1_sim = scr[:, 0]
        margin = scr[:, 0] - scr[:, 1] if scr.shape[1] > 1 else scr[:, 0]
        ambiguity = np.clip((margin_hi - margin) / (margin_hi - margin_lo + 1e-10), 0.0, 1.0)
        entropy = -(pos_w * np.log(pos_w + 1e-10)).sum(axis=1) / np.log(max(pos_w.shape[1], 2))
        entropy_gate = np.clip(ambiguity * (0.65 + CONFIG["obj3_entropy_gamma"] * entropy), 0.0, 1.0)
        quality_gate = np.clip((q_hi - q_quality) / (q_hi - q_lo + 1e-10), 0.0, 1.0)

        sims_gallery = np.dot(q, G.T).astype(np.float32)
        gm = min(vote_topm, sims_gallery.shape[1])
        gidx = np.argpartition(-sims_gallery, kth=gm - 1, axis=1)[:, :gm]
        gscr = np.take_along_axis(sims_gallery, gidx, axis=1)
        gord = np.argsort(-gscr, axis=1)
        gidx = np.take_along_axis(gidx, gord, axis=1)
        gscr = np.take_along_axis(gscr, gord, axis=1)
        top_gallery_ids = G_ids[gidx]

        local_sameid = np.zeros_like(pos_agg)
        top_proto_ids = proto_ids[pos_idx[:, 0]]
        agree = []
        local_support = np.zeros(len(q), dtype=np.float32)

        for i in range(len(q)):
            pid = str(top_proto_ids[i])
            row_ids = top_gallery_ids[i]
            same_votes = float(np.mean(row_ids[:max(1, gm)] == pid))
            agree.append(same_votes)
            same_idx = id_to_gidx.get(pid, [])
            if same_idx:
                same_idx = np.asarray(same_idx, dtype=np.int32)
                sims_same = sims_gallery[i, same_idx]
                take_same = min(local_sameid_topm, len(same_idx))
                if take_same > 0:
                    top_same_local = np.argpartition(-sims_same, kth=take_same - 1)[:take_same]
                    local = G[same_idx[top_same_local]].mean(axis=0, keepdims=True)
                    local_sameid[i] = l2n_rows(local)[0]
                    local_support[i] = float(np.mean(np.sort(sims_same[top_same_local])[::-1]))
        agree = np.asarray(agree, dtype=np.float32)
        consistency_gate = np.clip(CONFIG["obj3_consistency_floor"] + (1.0 - CONFIG["obj3_consistency_floor"]) * agree, 0.0, 1.0)

        sim_gate = np.clip((top1_sim - top1_sim_lo) / (1.0 - top1_sim_lo + 1e-10), 0.0, 1.0)
        target = l2n_rows(
            target_proto_blend * pos_agg
            + CONFIG["obj3_proto_support_weight"] * local_sameid
            + (1.0 - target_proto_blend - CONFIG["obj3_proto_support_weight"]) * q
        )

        alpha = max_alpha * (0.50 + 0.50 * quality_gate) * (0.50 + 0.50 * entropy_gate) * consistency_gate * sim_gate
        alpha = np.clip(alpha, 0.0, max_alpha)

        competitor_scale = competitor_gamma * (0.5 + 0.5 * ambiguity)[:, None]
        q_new = l2n_rows(q + alpha[:, None] * (target - competitor_scale * neg_agg))
        out[start:start + batch_size] = q_new.astype(np.float32)

        strengths.extend(alpha.astype(np.float32).tolist())
        margins.extend(margin.astype(np.float32).tolist())
        agreements.extend(agree.astype(np.float32).tolist())
        top1_sims.extend(top1_sim.astype(np.float32).tolist())
        entropies.extend(entropy.astype(np.float32).tolist())
        quality_gates.extend(quality_gate.astype(np.float32).tolist())
        ambiguity_gates.extend(entropy_gate.astype(np.float32).tolist())
        consistency_gates.extend(consistency_gate.astype(np.float32).tolist())
        local_supports.extend(local_support.astype(np.float32).tolist())

    stats = {
        "strength_mean": float(np.mean(strengths)) if strengths else 0.0,
        "strength_std": float(np.std(strengths)) if strengths else 0.0,
        "strength_max": float(np.max(strengths)) if strengths else 0.0,
        "margin_mean": float(np.mean(margins)) if margins else 0.0,
        "agreement_rate": float(np.mean(agreements)) if agreements else 0.0,
        "top1_sim_mean": float(np.mean(top1_sims)) if top1_sims else 0.0,
        "entropy_mean": float(np.mean(entropies)) if entropies else 0.0,
        "quality_gate_mean": float(np.mean(quality_gates)) if quality_gates else 0.0,
        "ambiguity_gate_mean": float(np.mean(ambiguity_gates)) if ambiguity_gates else 0.0,
        "consistency_gate_mean": float(np.mean(consistency_gates)) if consistency_gates else 0.0,
        "local_support_mean": float(np.mean(local_supports)) if local_supports else 0.0,
    }
    diag = {
        "strength": np.asarray(strengths, dtype=np.float32),
        "margin": np.asarray(margins, dtype=np.float32),
        "agree": np.asarray(agreements, dtype=np.float32),
        "top1_sim": np.asarray(top1_sims, dtype=np.float32),
        "entropy": np.asarray(entropies, dtype=np.float32),
        "quality_gate": np.asarray(quality_gates, dtype=np.float32),
        "ambiguity_gate": np.asarray(ambiguity_gates, dtype=np.float32),
        "consistency_gate": np.asarray(consistency_gates, dtype=np.float32),
        "local_support": np.asarray(local_supports, dtype=np.float32),
    }
    return out.astype(np.float32), stats, diag


def reciprocal_candidate_signals(
    query_feat: np.ndarray,
    cand_feats: np.ndarray,
    cand_ids: np.ndarray,
    top_proto_id: Optional[str] = None,
    q_topk: int = CONFIG["obj3_recip_query_k"],
    cand_topk: int = CONFIG["obj3_recip_cand_k"],
) -> Tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
    cand = l2n_rows(cand_feats)
    n = cand.shape[0]
    if n == 0:
        z = np.zeros((0,), dtype=np.float32)
        return z, z, z, z, z

    local = np.vstack([query_feat[None], cand]).astype(np.float32)
    sims = np.dot(local, local.T).astype(np.float32)
    np.fill_diagonal(sims, -1e9)

    q_to_c = sims[0, 1:].copy()
    kq = min(max(1, q_topk), n)
    if kq >= n:
        q_idx = np.argsort(-q_to_c)[:kq]
    else:
        q_idx = np.argpartition(-q_to_c, kth=kq - 1)[:kq]
        q_idx = q_idx[np.argsort(-q_to_c[q_idx])]
    q_set = set(int(x) for x in q_idx.tolist())

    overlap = np.zeros(n, dtype=np.float32)
    mutual = np.zeros(n, dtype=np.float32)
    local_support = np.zeros(n, dtype=np.float32)
    proto_match = np.zeros(n, dtype=np.float32)

    for j in range(n):
        row = sims[j + 1].copy()
        kc = min(max(2, cand_topk + 1), n + 1)
        if kc >= len(row):
            cand_all = np.argsort(-row)[:kc]
        else:
            cand_all = np.argpartition(-row, kth=kc - 1)[:kc]
            cand_all = cand_all[np.argsort(-row[cand_all])]

        mutual[j] = 1.0 if 0 in cand_all else 0.0

        cand_neighbors = np.asarray([ix - 1 for ix in cand_all if ix > 0], dtype=np.int32)
        cand_set = set(int(x) for x in cand_neighbors.tolist())
        union = q_set | cand_set
        if len(union) > 0:
            overlap[j] = float(len(q_set & cand_set) / len(union))
        if len(cand_neighbors) > 0:
            local_support[j] = float(np.mean(q_to_c[cand_neighbors]))
        if top_proto_id is not None and str(cand_ids[j]) == str(top_proto_id):
            proto_match[j] = 1.0

    local_support = np.clip((local_support + 1.0) * 0.5, 0.0, 1.0).astype(np.float32)
    return overlap, mutual, local_support, proto_match, q_to_c

def evaluate_tinyface_obj3plus_reciprocal_rerank(
    P: np.ndarray,
    P_ids: np.ndarray,
    G: np.ndarray,
    G_ids: np.ndarray,
    Proto: np.ndarray,
    Proto_ids: np.ndarray,
    D: Optional[np.ndarray],
    probe_quality: Optional[np.ndarray] = None,
    ranks: Tuple[int, ...] = (1, 5, 20),
    probe_batch: int = CONFIG["tinyface_probe_batch"],
    candidate_gallery_k: int = CONFIG["obj3_tinyface_candidate_gallery"],
    candidate_distractor_k: int = CONFIG["obj3_tinyface_candidate_distractor"],
    proto_weight: float = CONFIG["obj3_tinyface_proto_weight"],
    id_weight: float = CONFIG["obj3_tinyface_id_weight"],
    distractor_penalty: float = CONFIG["obj3_tinyface_distractor_penalty"],
    recip_query_k: int = CONFIG["obj3_recip_query_k"],
    recip_cand_k: int = CONFIG["obj3_recip_cand_k"],
    recip_overlap_weight: float = CONFIG["obj3_recip_overlap_weight"],
    recip_mutual_weight: float = CONFIG["obj3_recip_mutual_weight"],
    recip_local_weight: float = CONFIG["obj3_recip_local_weight"],
    recip_proto_consistency_weight: float = CONFIG["obj3_recip_proto_consistency_weight"],
    recip_rank_decay_weight: float = CONFIG["obj3_recip_rank_decay_weight"],
    proto_rel: Optional[np.ndarray] = None,
) -> Dict[str, float]:
    rng = np.random.default_rng(SEED)
    P = l2n_rows(P)
    G = l2n_rows(G)
    Proto = l2n_rows(Proto)
    D = np.zeros((0, G.shape[1]), dtype=np.float32) if D is None else l2n_rows(D)

    if probe_quality is None or len(probe_quality) != len(P):
        probe_quality = np.ones(len(P), dtype=np.float32)
    else:
        probe_quality = np.nan_to_num(
            np.asarray(probe_quality, dtype=np.float32),
            nan=0.5, posinf=1.0, neginf=0.0
        )

    if proto_rel is not None:
        proto_rel = np.nan_to_num(
            np.asarray(proto_rel, dtype=np.float32),
            nan=CONFIG.get("obj3_proto_default_rel", 0.50),
            posinf=1.0, neginf=0.0
        )
        proto_rel = np.clip(proto_rel, 0.0, 1.0)

    id_to_proto = {str(pid): i for i, pid in enumerate(Proto_ids)}
    _default_rel = CONFIG.get("obj3_proto_default_rel", 0.50)
    _use_rel = CONFIG.get("obj3_use_reliability_gating", True) and proto_rel is not None
    # When DPRG is off, rho=1.0 so scoring reverts to original (no modulation)
    _fallback_rel = 1.0 if not _use_rel else _default_rel
    ranks = tuple(sorted(ranks))
    max_rank = max(ranks)

    hits = {r: 0 for r in ranks}
    pos_scores, neg_scores = [], []
    raw_pos_scores, raw_neg_scores = [], []
    probe_ranks = []
    recip_overlap_vals, recip_mutual_vals, recip_local_vals, recip_proto_vals = [], [], [], []

    for start in tqdm(range(0, len(P), probe_batch), desc="Obj3++ TinyFace reciprocal rerank", leave=False):
        q = P[start:start + probe_batch]
        ids_chunk = np.asarray(P_ids[start:start + probe_batch])
        q_chunk = probe_quality[start:start + probe_batch]

        sims_g = np.dot(q, G.T).astype(np.float32)
        sims_p = np.dot(q, Proto.T).astype(np.float32)
        sims_d = np.dot(q, D.T).astype(np.float32) if len(D) > 0 else np.zeros((len(q), 0), dtype=np.float32)

        kg = min(candidate_gallery_k, sims_g.shape[1])
        kd = min(candidate_distractor_k, sims_d.shape[1]) if sims_d.shape[1] > 0 else 0

        topg_idx = np.argpartition(-sims_g, kth=kg - 1, axis=1)[:, :kg]
        topg_scr = np.take_along_axis(sims_g, topg_idx, axis=1)
        gsort = np.argsort(-topg_scr, axis=1)
        topg_idx = np.take_along_axis(topg_idx, gsort, axis=1)
        topg_scr = np.take_along_axis(topg_scr, gsort, axis=1)

        if kd > 0:
            topd_idx = np.argpartition(-sims_d, kth=kd - 1, axis=1)[:, :kd]
            topd_scr = np.take_along_axis(sims_d, topd_idx, axis=1)
            dsort = np.argsort(-topd_scr, axis=1)
            topd_idx = np.take_along_axis(topd_idx, dsort, axis=1)
            topd_scr = np.take_along_axis(topd_scr, dsort, axis=1)
        else:
            topd_idx = np.zeros((len(q), 0), dtype=np.int32)
            topd_scr = np.zeros((len(q), 0), dtype=np.float32)

        for i, true_id in enumerate(ids_chunk):
            cand_idx = topg_idx[i]
            cand_scr = topg_scr[i]
            cand_ids = G_ids[cand_idx]
            q_gate = float(np.clip(1.0 - q_chunk[i], 0.0, 1.0))

            # identity summary over current gallery candidate pool
            id_best, id_mean, id_consensus = {}, {}, {}
            ordered_seen = []
            for pid in cand_ids:
                spid = str(pid)
                if spid not in id_best:
                    ordered_seen.append(spid)
            for pid in ordered_seen:
                mask = (cand_ids == pid)
                vals = cand_scr[mask]
                id_best[pid] = float(vals.max())
                id_mean[pid] = float(vals[: min(3, len(vals))].mean())
                id_consensus[pid] = float(mask.mean())

            top_proto_idx = int(np.argmax(sims_p[i])) if sims_p.shape[1] > 0 else -1
            top_proto_id = str(Proto_ids[top_proto_idx]) if top_proto_idx >= 0 else None

            fused_gallery, fused_gallery_ids = [], []
            for rank_pos, (gi, raw) in enumerate(zip(cand_idx, cand_scr)):
                pid = str(G_ids[gi])
                pidx = id_to_proto.get(pid, None)
                pscore = float(sims_p[i, pidx]) if pidx is not None else -1.0
                idboost = 0.5 * id_best.get(pid, raw) + 0.5 * id_mean.get(pid, raw)
                rank_boost = CONFIG["obj3_rank_fusion_weight"] * (1.0 / (rank_pos + 1))
                # DPRG: modulate proto/id/consensus by reliability
                rho = float(proto_rel[pidx]) if (_use_rel and pidx is not None) else _fallback_rel
                fused = float(
                    raw
                    + proto_weight * (0.55 + 0.45 * q_gate) * rho * pscore
                    + id_weight * (rho ** 0.5) * idboost
                    + rank_boost
                    + CONFIG["obj3_consensus_weight"] * rho * id_consensus.get(pid, 0.0)
                )
                fused_gallery.append(fused)
                fused_gallery_ids.append(pid)

            if kd > 0:
                topd = topd_scr[i]
                d_margin = float(topd[0] - topd[min(1, len(topd) - 1)]) if len(topd) > 1 else float(topd[0])
                fused_d = [float(s - distractor_penalty - CONFIG["obj3_distractor_margin_penalty"] * d_margin) for s in topd]
                cand_feats_d = D[topd_idx[i]]
            else:
                fused_d = []
                cand_feats_d = np.zeros((0, G.shape[1]), dtype=np.float32)

            cand_feats = np.vstack([G[cand_idx], cand_feats_d]).astype(np.float32)
            all_scores = np.asarray(fused_gallery + fused_d, dtype=np.float32)
            all_ids = np.asarray(fused_gallery_ids + ["-1"] * len(fused_d), dtype=object)

            overlap, mutual, local_support, proto_match, q_to_c = reciprocal_candidate_signals(
                q[i], cand_feats, all_ids, top_proto_id=top_proto_id,
                q_topk=recip_query_k, cand_topk=recip_cand_k
            )

            recip_scale = (0.55 + 0.45 * q_gate)
            gallery_mask = (all_ids != "-1")
            rank_order0 = np.argsort(-all_scores)
            rank_pos = np.empty(len(all_scores), dtype=np.float32)
            rank_pos[rank_order0] = np.arange(len(all_scores), dtype=np.float32)
            rank_decay = 1.0 / (1.0 + rank_pos)

            boosts = recip_scale * (
                recip_overlap_weight * overlap
                + recip_mutual_weight * mutual
                + recip_local_weight * local_support
                + recip_proto_consistency_weight * proto_match
            ) + recip_rank_decay_weight * rank_decay
            boosts[~gallery_mask] *= 0.60
            final_scores = all_scores + boosts.astype(np.float32)

            take = min(max_rank, len(final_scores))
            order = np.argpartition(-final_scores, kth=take - 1)[:take]
            order = order[np.argsort(-final_scores[order])]
            pred_ids = all_ids[order]

            for r in ranks:
                if true_id in pred_ids[:r]:
                    hits[r] += 1

            # Track per-probe rank for CMC curve
            first_hit = -1
            for rr in range(len(pred_ids)):
                if pred_ids[rr] == true_id:
                    first_hit = rr
                    break
            probe_ranks.append(first_hit if first_hit >= 0 else max_rank + 1)

            pos_mask = (all_ids == true_id)
            if np.any(pos_mask):
                pos_scores.append(float(final_scores[pos_mask].max()))
            elif np.any(G_ids == true_id):
                pos_scores.append(float(np.dot(q[i], G[G_ids == true_id].T).max()))

            # RAW cosine scores for AUX_AUC (avoids fusion bias)
            if np.any(G_ids == true_id):
                raw_pos_scores.append(float(np.dot(q[i], G[G_ids == true_id].T).max()))

            if len(D) > 0:
                neg_take = min(CONFIG["tinyface_aux_neg_per_probe"], D.shape[0])
                rand_neg = rng.choice(D.shape[0], size=neg_take, replace=False)
                raw_neg = np.dot(q[i:i+1], D[rand_neg].T).astype(np.float32).ravel()
                raw_neg_scores.extend(raw_neg.tolist())

            if len(fused_d) > 0:
                neg_take = min(CONFIG["tinyface_aux_neg_per_probe"], len(fused_d))
                neg_idx = np.argsort(-np.asarray(fused_d, dtype=np.float32))[:neg_take]
                neg_scores.extend(final_scores[len(fused_gallery) + neg_idx].astype(np.float32).tolist())
            elif len(D) > 0:
                neg_take = min(CONFIG["tinyface_aux_neg_per_probe"], D.shape[0])
                rand_neg2 = rng.choice(D.shape[0], size=neg_take, replace=False)
                neg_scores.extend(np.dot(q[i:i+1], D[rand_neg2].T).astype(np.float32).ravel().tolist())

            recip_overlap_vals.append(float(overlap.mean()) if len(overlap) else 0.0)
            recip_mutual_vals.append(float(mutual.mean()) if len(mutual) else 0.0)
            recip_local_vals.append(float(local_support.mean()) if len(local_support) else 0.0)
            recip_proto_vals.append(float(proto_match.mean()) if len(proto_match) else 0.0)

    n_probe = len(P)
    out = {f"rank_{r}": float(hits[r] / n_probe) for r in ranks}

    # Fused-score AUC (for ranking evaluation)
    if len(pos_scores) > 0 and len(neg_scores) > 0:
        y_true_f = np.concatenate([np.ones(len(pos_scores), dtype=np.int32), np.zeros(len(neg_scores), dtype=np.int32)])
        y_score_f = np.concatenate([np.asarray(pos_scores, dtype=np.float32), np.asarray(neg_scores, dtype=np.float32)])
        fpr_f, tpr_f, _ = roc_curve(y_true_f, y_score_f)
        out["fused_auc"] = float(auc(fpr_f, tpr_f))
        fnr_f = 1.0 - tpr_f
        out["fused_eer"] = float(fpr_f[np.nanargmin(np.abs(fpr_f - fnr_f))])

    # Raw cosine AUC (unbiased discriminability measure)
    if len(raw_pos_scores) > 0 and len(raw_neg_scores) > 0:
        y_true = np.concatenate([np.ones(len(raw_pos_scores), dtype=np.int32), np.zeros(len(raw_neg_scores), dtype=np.int32)])
        y_score = np.concatenate([np.asarray(raw_pos_scores, dtype=np.float32), np.asarray(raw_neg_scores, dtype=np.float32)])
        fpr, tpr, _ = roc_curve(y_true, y_score)
        out["aux_auc"] = float(auc(fpr, tpr))
        fnr = 1.0 - tpr
        out["aux_eer"] = float(fpr[np.nanargmin(np.abs(fpr - fnr))])
        # Save ROC data for TinyFace plot
        roc_path = RESULTS_DIR / "roc_tinyface_aux.npz"
        np.savez_compressed(roc_path, fpr=fpr.astype(np.float32), tpr=tpr.astype(np.float32))
        out["roc_path"] = str(roc_path)
    else:
        out["aux_auc"] = float("nan")
        out["aux_eer"] = float("nan")
    out["n_probe"] = int(n_probe)

    # CMC curve data
    probe_ranks_arr = np.asarray(probe_ranks, dtype=np.int32)
    cmc = np.zeros(max_rank, dtype=np.float32)
    for r_idx in range(max_rank):
        cmc[r_idx] = float(np.mean(probe_ranks_arr <= r_idx))
    cmc_path = RESULTS_DIR / "cmc_tinyface.npz"
    np.savez_compressed(cmc_path, cmc=cmc, ranks=np.arange(1, max_rank + 1))
    out["cmc_path"] = str(cmc_path)

    # Save per-probe rank positions for failure analysis
    ranks_path = RESULTS_DIR / "tinyface_probe_ranks.npz"
    np.savez_compressed(ranks_path,
        probe_ranks=probe_ranks_arr,
        probe_ids=np.asarray(P_ids, dtype=str))
    out["ranks_path"] = str(ranks_path)
    out["recip_overlap_mean"] = float(np.mean(recip_overlap_vals)) if len(recip_overlap_vals) else 0.0
    out["recip_mutual_mean"] = float(np.mean(recip_mutual_vals)) if len(recip_mutual_vals) else 0.0
    out["recip_local_support_mean"] = float(np.mean(recip_local_vals)) if len(recip_local_vals) else 0.0
    out["recip_proto_match_mean"] = float(np.mean(recip_proto_vals)) if len(recip_proto_vals) else 0.0
    return out

def query_expansion_pass(
    P_cal: np.ndarray,
    G: np.ndarray,
    G_ids: np.ndarray,
    probe_quality: Optional[np.ndarray] = None,
    qe_topk: int = 3,
    qe_alpha: float = 0.40,
    batch_size: int = 256,
) -> np.ndarray:
    """
    Alpha-weighted query expansion (alpha-QE).
    For each calibrated probe, find top-k gallery neighbors,
    compute weighted average, blend back with probe.
    """
    Q = l2n_rows(P_cal)
    Gn = l2n_rows(G)

    if probe_quality is None or len(probe_quality) != len(Q):
        probe_quality = np.ones(len(Q), dtype=np.float32)
    else:
        probe_quality = np.asarray(probe_quality, dtype=np.float32)

    q_lo = float(np.percentile(probe_quality, 25))
    q_hi = float(np.percentile(probe_quality, 75))

    out = np.zeros_like(Q, dtype=np.float32)
    for start in range(0, len(Q), batch_size):
        q_batch = Q[start:start + batch_size]
        qq = probe_quality[start:start + batch_size]
        sims = np.dot(q_batch, Gn.T).astype(np.float32)
        k = min(qe_topk, sims.shape[1])
        topk_idx = np.argpartition(-sims, kth=k - 1, axis=1)[:, :k]
        topk_scr = np.take_along_axis(sims, topk_idx, axis=1)

        # Sort within top-k
        sort_order = np.argsort(-topk_scr, axis=1)
        topk_idx = np.take_along_axis(topk_idx, sort_order, axis=1)
        topk_scr = np.take_along_axis(topk_scr, sort_order, axis=1)

        # Weighted neighbor aggregation
        topk_feats = Gn[topk_idx]  # (batch, k, dim)
        w = softmax_np(topk_scr, tau=0.05)  # (batch, k)
        neighbor_agg = (topk_feats * w[:, :, None]).sum(axis=1)  # (batch, dim)

        # Quality-adaptive alpha
        q_gate = np.clip((q_hi - qq) / (q_hi - q_lo + 1e-10), 0.0, 1.0)
        alpha = qe_alpha * (0.55 + 0.45 * q_gate)

        expanded = (1.0 - alpha[:, None]) * q_batch + alpha[:, None] * neighbor_agg
        out[start:start + batch_size] = l2n_rows(expanded).astype(np.float32)

    return out


def gallery_dba_pass(
    G: np.ndarray,
    G_ids: np.ndarray,
    topk: int = 2,
    alpha: float = 0.12,
) -> np.ndarray:
    """
    Database-side augmentation (DBA) pass on gallery.
    Each gallery embedding is blended with its top-k same-ID neighbors.
    """
    Gn = l2n_rows(G)
    id_to_idx = defaultdict(list)
    for i, pid in enumerate(G_ids):
        id_to_idx[str(pid)].append(i)

    out = Gn.copy()
    for pid, idxs in id_to_idx.items():
        if len(idxs) < 2:
            continue
        group = Gn[idxs]
        sims = np.dot(group, group.T).astype(np.float32)
        np.fill_diagonal(sims, -1e9)
        k = min(topk, len(idxs) - 1)
        for local_i in range(len(idxs)):
            top_local = np.argpartition(-sims[local_i], kth=k - 1)[:k]
            neighbor_mean = group[top_local].mean(axis=0)
            out[idxs[local_i]] = (1.0 - alpha) * Gn[idxs[local_i]] + alpha * neighbor_mean

    return l2n_rows(out).astype(np.float32)

def estimate_onnx_backbone_flops(rec_model_obj) -> Dict[str, float]:
    try:
        import onnx
        from onnx import numpy_helper, shape_inference
    except Exception as e:
        return {"status": "skipped", "reason": f"onnx import failed: {e}"}

    model_path = getattr(rec_model_obj, "model_file", None)
    if model_path is None:
        model_path = getattr(rec_model_obj, "model_path", None)
    if model_path is None or not os.path.exists(model_path):
        return {"status": "skipped", "reason": "recognition ONNX model path unavailable"}

    try:
        model = onnx.load(model_path)
        model = shape_inference.infer_shapes(model)
    except Exception as e:
        return {"status": "skipped", "reason": f"onnx shape inference failed: {e}"}

    def tensor_shape(vi):
        dims = []
        tt = vi.type.tensor_type
        if not tt.HasField("shape"):
            return None
        for d in tt.shape.dim:
            if d.HasField("dim_value"):
                dims.append(int(d.dim_value))
            else:
                return None
        return dims

    value_infos = {}
    for vi in list(model.graph.input) + list(model.graph.output) + list(model.graph.value_info):
        shp = tensor_shape(vi)
        if shp is not None:
            value_infos[vi.name] = shp

    inits = {x.name: numpy_helper.to_array(x) for x in model.graph.initializer}

    def get_shape(name):
        if name in value_infos:
            return value_infos[name]
        if name in inits:
            return list(inits[name].shape)
        return None

    total_flops = 0.0
    conv_flops = 0.0
    gemm_flops = 0.0
    for node in model.graph.node:
        op = node.op_type
        if op == "Conv" and len(node.input) >= 2:
            xshape = get_shape(node.input[0])
            w = inits.get(node.input[1], None)
            yshape = get_shape(node.output[0])
            if xshape is None or w is None or yshape is None or len(yshape) < 4:
                continue
            n, cout, hout, wout = yshape[:4]
            cin_group = int(w.shape[1])
            kh, kw = int(w.shape[2]), int(w.shape[3])
            fl = 2.0 * n * cout * hout * wout * cin_group * kh * kw
            conv_flops += fl
            total_flops += fl
        elif op in ("Gemm", "MatMul") and len(node.input) >= 2:
            ashape = get_shape(node.input[0])
            bshape = get_shape(node.input[1])
            if ashape is None or bshape is None:
                continue
            if len(ashape) >= 2 and len(bshape) >= 2:
                m = int(np.prod(ashape[:-1]))
                k = int(ashape[-1])
                n = int(bshape[-1])
                fl = 2.0 * m * k * n
                gemm_flops += fl
                total_flops += fl
    return {
        "status": "ok",
        "model_path": model_path,
        "gflops_total": float(total_flops / 1e9),
        "gflops_conv": float(conv_flops / 1e9),
        "gflops_gemm": float(gemm_flops / 1e9),
    }

