    adapter_tf["adapter_config_path"] = str(adapter_cfg_path)
    adapter_tf["adapter_quality_edges"] = adapter_edges.astype(np.float32)
    adapter_tf = qpearl_adapter_attach_artifacts(adapter_tf, "qpearl_adapter_plus_final")
    OBJ3_RESULTS["TinyFace_QPEARL_Adapter_plus"] = adapter_tf

    print("Q-PEARL-Adapter++ TEST Rank-1:", 100 * adapter_tf["rank_1"])
