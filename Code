def _l2n_rows(x, eps=1e-12):
    x = np.asarray(x, dtype=np.float32)
    return x / np.maximum(np.linalg.norm(x, axis=1, keepdims=True), eps)


def _as_ids(x, n=None, fill="-1"):
    if x is None:
        if n is None:
            return np.asarray([], dtype=str)
        return np.asarray([fill] * n, dtype=str)
    return np.asarray(x).astype(str)


def _chunked_topk(P, G, topk, probe_batch=64, gallery_chunk=32768):
    """
    Memory-safe top-k search.
    Returns top_scores and top_indices for each probe.
    """
    P = np.asarray(P, dtype=np.float32)
    G = np.asarray(G, dtype=np.float32)

    n_probe = P.shape[0]
    n_gallery = G.shape[0]
    topk = min(int(topk), n_gallery)

    all_top_scores = np.empty((n_probe, topk), dtype=np.float32)
    all_top_indices = np.empty((n_probe, topk), dtype=np.int32)

    for ps in tqdm(range(0, n_probe, probe_batch), desc="Frozen top-k search"):
        pe = min(ps + probe_batch, n_probe)
        Pb = P[ps:pe]

        cur_scores = np.full((pe - ps, topk), -np.inf, dtype=np.float32)
        cur_indices = np.full((pe - ps, topk), -1, dtype=np.int32)

        for gs in range(0, n_gallery, gallery_chunk):
            ge = min(gs + gallery_chunk, n_gallery)
            scores = Pb @ G[gs:ge].T

            k_local = min(topk, scores.shape[1])
            idx_local = np.argpartition(-scores, kth=k_local - 1, axis=1)[:, :k_local]
            sc_local = np.take_along_axis(scores, idx_local, axis=1)
            idx_local = idx_local + gs

            merged_scores = np.concatenate([cur_scores, sc_local], axis=1)
            merged_indices = np.concatenate([cur_indices, idx_local.astype(np.int32)], axis=1)

            idx_keep = np.argpartition(-merged_scores, kth=topk - 1, axis=1)[:, :topk]
            cur_scores = np.take_along_axis(merged_scores, idx_keep, axis=1)
            cur_indices = np.take_along_axis(merged_indices, idx_keep, axis=1)

        order = np.argsort(-cur_scores, axis=1)
        all_top_scores[ps:pe] = np.take_along_axis(cur_scores, order, axis=1)
        all_top_indices[ps:pe] = np.take_along_axis(cur_indices, order, axis=1)

    return all_top_scores, all_top_indices


def _local_reciprocal_rerank(P, G, top_scores, top_indices, recip_k=20, local_k=10, rr_lambda=0.20):
    """
    Lightweight local reciprocal reranking over each probe's top-K candidate set.

    This avoids full gallery-gallery similarity and is suitable for TinyFace-scale
    ablation. It does not use the Q-PEARL adapter.
    """
    n_probe, topk = top_indices.shape

    reranked_indices = np.empty_like(top_indices)
    reranked_scores = np.empty_like(top_scores)

    recip_k = max(1, min(int(recip_k), topk))
    local_k = max(1, min(int(local_k), max(1, topk - 1)))
    rr_lambda = float(rr_lambda)

    for i in tqdm(range(n_probe), desc="Frozen reciprocal reranking"):
        cand_idx = top_indices[i]
        orig = top_scores[i].astype(np.float32)

        C = G[cand_idx]
        cc = C @ C.T
        np.fill_diagonal(cc, -np.inf)

        # Candidate considers probe reciprocal if probe similarity is among
        # the candidate's local top-k neighborhood.
        probe_rank_from_candidate = 1 + np.sum(cc > orig[:, None], axis=1)

        reciprocal_strength = np.clip(
            (recip_k - probe_rank_from_candidate + 1) / float(recip_k),
            0.0,
            1.0,
        )

        # Local density among candidate neighborhood.
        if topk > 1:
            k_density = min(local_k, topk - 1)
            local_top = -np.partition(-cc, kth=k_density - 1, axis=1)[:, :k_density]
            local_density = np.mean(local_top, axis=1)
            local_density = np.clip((local_density + 1.0) / 2.0, 0.0, 1.0)
        else:
            local_density = np.zeros_like(orig)

        # Convert local bonus to cosine-like range [-1, 1].
        local_bonus = 0.65 * reciprocal_strength + 0.35 * local_density
        local_bonus = (2.0 * local_bonus) - 1.0

        final_score = (1.0 - rr_lambda) * orig + rr_lambda * local_bonus

        order = np.argsort(-final_score)

        reranked_indices[i] = cand_idx[order]
        reranked_scores[i] = final_score[order]

    return reranked_scores, reranked_indices


def _evaluate_ranked_indices(ranked_indices, gallery_ids, probe_ids, probe_quality=None, max_cmc=100):
    gallery_ids = np.asarray(gallery_ids).astype(str)
    probe_ids = np.asarray(probe_ids).astype(str)

    n_probe = len(probe_ids)
    max_rank_available = ranked_indices.shape[1]

    probe_ranks = np.full(n_probe, 10**9, dtype=np.int32)

    for i in range(n_probe):
        ids_i = gallery_ids[ranked_indices[i]]
        hit = np.where(ids_i == probe_ids[i])[0]
        if len(hit) > 0:
            probe_ranks[i] = int(hit[0])

    def rank_acc(k):
        return float(np.mean(probe_ranks < k))

    out = {
        "rank_1": rank_acc(1),
        "rank_5": rank_acc(5),
        "rank_10": rank_acc(10),
        "rank_20": rank_acc(20),
        "mAP": float(np.mean(np.where(probe_ranks < max_rank_available, 1.0 / (probe_ranks + 1), 0.0))),
        "top100_recall": rank_acc(100) if max_rank_available >= 100 else np.nan,
    }

    max_cmc = min(int(max_cmc), max_rank_available)
    cmc_ranks = np.arange(1, max_cmc + 1, dtype=np.int32)
    cmc = np.asarray([rank_acc(k) for k in cmc_ranks], dtype=np.float32)

    if probe_quality is None:
        probe_quality = np.full(n_probe, np.nan, dtype=np.float32)

    return out, probe_ranks, probe_quality, cmc_ranks, cmc


