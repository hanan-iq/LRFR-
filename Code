def safe_quality_array(values, default=0.5):
    arr = np.asarray(values, dtype=np.float32).reshape(-1)
    if arr.size == 0:
        return np.zeros((0,), dtype=np.float32)
    arr = np.nan_to_num(arr, nan=default, posinf=1.0, neginf=0.0)
    return np.clip(arr, 0.0, 1.0).astype(np.float32)

def safe_quality_column(values, default=0.5):
    return safe_quality_array(values, default=default).reshape(-1, 1)

def compute_quality_for_images(imgs_bgr_list):
    quals = []
    for img in imgs_bgr_list:
        try:
            q = float(image_quality_score(img))
        except Exception:
            q = 0.5
        quals.append(q)
    return safe_quality_array(quals)

def mild_elastic_deform(img_bgr, alpha=1.4, sigma=10.0, rng=None):
    if rng is None:
        rng = np.random.default_rng()
    h, w = img_bgr.shape[:2]
    dx = rng.standard_normal((h, w)).astype(np.float32)
    dy = rng.standard_normal((h, w)).astype(np.float32)
    dx = cv2.GaussianBlur(dx, (0, 0), sigmaX=float(sigma), sigmaY=float(sigma)) * float(alpha)
    dy = cv2.GaussianBlur(dy, (0, 0), sigmaX=float(sigma), sigmaY=float(sigma)) * float(alpha)
    grid_x, grid_y = np.meshgrid(np.arange(w, dtype=np.float32), np.arange(h, dtype=np.float32))
    map_x = np.clip(grid_x + dx, 0, w - 1).astype(np.float32)
    map_y = np.clip(grid_y + dy, 0, h - 1).astype(np.float32)
    return cv2.remap(img_bgr, map_x, map_y, interpolation=cv2.INTER_LINEAR, borderMode=cv2.BORDER_REFLECT_101)

def jpeg_compress(img_bgr, quality=60):
    ok, enc = cv2.imencode(".jpg", img_bgr, [int(cv2.IMWRITE_JPEG_QUALITY), int(quality)])
    if not ok:
        return img_bgr
    dec = cv2.imdecode(enc, cv2.IMREAD_COLOR)
    return dec if dec is not None else img_bgr

def alignment_perturb(img_bgr, jitter_px=4, rot_deg=8.0, scale_range=(0.90, 1.10), rng=None):
    if rng is None:
        rng = np.random.default_rng()
    h, w = img_bgr.shape[:2]
    cx, cy = w / 2.0, h / 2.0
    tx = rng.uniform(-jitter_px, jitter_px)
    ty = rng.uniform(-jitter_px, jitter_px)
    angle = rng.uniform(-rot_deg, rot_deg)
    scale = rng.uniform(scale_range[0], scale_range[1])
    M = cv2.getRotationMatrix2D((cx + tx, cy + ty), angle, scale)
    out = cv2.warpAffine(img_bgr, M, (w, h), borderMode=cv2.BORDER_REFLECT_101)

    if rng.random() < float(CONFIG.get("qpearl_align_elastic_prob", 0.0)):
        out = mild_elastic_deform(
            out,
            alpha=float(CONFIG.get("qpearl_align_elastic_alpha", 1.4)),
            sigma=float(CONFIG.get("qpearl_align_elastic_sigma", 10.0)),
            rng=rng,
        )
    if rng.random() < float(CONFIG.get("qpearl_align_blur_prob", 0.0)):
        sigma_lo, sigma_hi = CONFIG.get("qpearl_align_blur_sigma", [0.4, 1.1])
        sigma = float(rng.uniform(float(sigma_lo), float(sigma_hi)))
        out = cv2.GaussianBlur(out, (0, 0), sigmaX=sigma, sigmaY=sigma)
    if rng.random() < float(CONFIG.get("qpearl_align_jpeg_prob", 0.0)):
        q_lo, q_hi = CONFIG.get("qpearl_align_jpeg_quality_range", [40, 85])
        out = jpeg_compress(out, quality=int(rng.integers(int(q_lo), int(q_hi) + 1)))
    return out

def lr_degrade(img_bgr, lr_size, rng=None):
    if rng is None:
        rng = np.random.default_rng()
    h, w = img_bgr.shape[:2]
    small = cv2.resize(img_bgr, (lr_size, lr_size), interpolation=cv2.INTER_LINEAR)
    up = cv2.resize(small, (w, h), interpolation=cv2.INTER_CUBIC)
    return up

class QPEARLAdapter(nn.Module):
    """
    Simplified Q-PEARL embedding-space adapter.

    The final Obj3 removes the quality-gated dual-branch router because prior
    ablation showed no gain on TinyFace. Instead, it uses:
    1. a single low-rank residual adapter in embedding space
    2. a projection residual block
    3. a small teacher-preserving blend with the original embedding
    This stays compatible with the ONNX backbone while keeping the method
    parameter-efficient and retrieval-oriented.
    """
    def __init__(self, dim=512, rank=64, hidden=256, init_scale=0.10, teacher_blend=0.15):
        super().__init__()
        self.res_down = nn.Linear(dim, rank)
        self.res_up = nn.Linear(rank, dim)
        self.res_scale = nn.Parameter(torch.tensor(float(init_scale)))

        self.proj = nn.Sequential(
            nn.Linear(dim, hidden),
            nn.GELU(),
            nn.Linear(hidden, dim),
        )
        self.proj_scale = nn.Parameter(torch.tensor(float(init_scale) * 0.5))
        self.teacher_blend = float(np.clip(teacher_blend, 0.0, 0.49))
        self._init_weights()

    def _init_weights(self):
        for m in [self.res_down, self.res_up]:
            nn.init.kaiming_normal_(m.weight, a=0.01)
            nn.init.zeros_(m.bias)
        for m in self.proj:
            if isinstance(m, nn.Linear):
                nn.init.kaiming_normal_(m.weight, a=0.01)
                nn.init.zeros_(m.bias)

    def forward(self, x, q=None, disable_quality_gate=False, force_alpha=None, teacher_blend_override=None):
        residual = x + self.res_scale * self.res_up(F.gelu(self.res_down(x)))
        residual = residual + self.proj_scale * self.proj(residual)

        beta = self.teacher_blend if teacher_blend_override is None else float(np.clip(teacher_blend_override, 0.0, 0.49))
        if not CONFIG.get("qpearl_use_teacher_blend", True):
            beta = 0.0

        out = (1.0 - beta) * residual + beta * x
        out = F.normalize(out, dim=1)

        # Keep a compatibility return value for earlier notebook utilities.
        alpha_val = 1.0 - beta
        alpha = torch.full((x.shape[0], 1), float(alpha_val), device=x.device, dtype=x.dtype)
        return out, alpha

class ArcFaceHead(nn.Module):
    def __init__(self, dim, num_classes, s=30.0, m=0.50):
        super().__init__()
        self.s = float(s)
        self.m = float(m)
        self.W = nn.Parameter(torch.empty(num_classes, dim))
        nn.init.xavier_uniform_(self.W)

    def forward(self, x, labels):
        W = F.normalize(self.W, dim=1)
        cos = F.linear(F.normalize(x, dim=1), W).clamp(-1 + 1e-7, 1 - 1e-7)
        theta = torch.acos(cos)
        one_hot = F.one_hot(labels, self.W.shape[0]).float()
        target_cos = torch.cos(theta + self.m * one_hot)
        logits = self.s * (cos + one_hot * (target_cos - cos))
        return logits

class QPEARLTrainDataset(Dataset):
    def __init__(self, embs_clean, embs_degraded, embs_misaligned,
                 quals_clean, quals_degraded, quals_misaligned, labels):
        self.embs_c = torch.from_numpy(np.asarray(embs_clean, dtype=np.float32))
        self.embs_d = torch.from_numpy(np.asarray(embs_degraded, dtype=np.float32))
        self.embs_m = torch.from_numpy(np.asarray(embs_misaligned, dtype=np.float32))
        self.q_c = torch.from_numpy(safe_quality_column(quals_clean))
        self.q_d = torch.from_numpy(safe_quality_column(quals_degraded))
        self.q_m = torch.from_numpy(safe_quality_column(quals_misaligned))
        self.labels = torch.from_numpy(np.asarray(labels, dtype=np.int64))

    def __len__(self):
        return int(len(self.labels))

    def __getitem__(self, idx):
        return {
            "emb_clean": self.embs_c[idx],
            "emb_degraded": self.embs_d[idx],
            "emb_misaligned": self.embs_m[idx],
            "q_clean": self.q_c[idx],
            "q_degraded": self.q_d[idx],
            "q_misaligned": self.q_m[idx],
            "label": self.labels[idx],
        }

def split_qpearl_indices(labels, val_split=0.10, seed=42):
    """Identity-disjoint train/val split for honest Q-PEARL validation.
    
    Unlike the prior sample-level split, this guarantees that no identity
    appears in both the train and val sets. The val_r1 metric is therefore
    a true measure of generalization to unseen people.
    """
    labels = np.asarray(labels, dtype=np.int64)
    n = len(labels)
    if n == 0:
        return np.asarray([], dtype=np.int64), np.asarray([], dtype=np.int64)
    unique_labels = np.unique(labels)
    n_ids = len(unique_labels)
    rng = np.random.default_rng(int(seed))
    perm = rng.permutation(n_ids)
    n_val_ids = max(1, int(round(n_ids * float(val_split))))
    n_val_ids = min(n_val_ids, max(1, int(round(n_ids * 0.20))))
    val_label_set = set(unique_labels[perm[:n_val_ids]].tolist())
    val_mask = np.array([int(l) in val_label_set for l in labels], dtype=bool)
    train_idx = np.where(~val_mask)[0].astype(np.int64)
    val_idx = np.where(val_mask)[0].astype(np.int64)
    # sanity check
    train_ids_set = set(np.unique(labels[train_idx]).tolist())
    val_ids_set = set(np.unique(labels[val_idx]).tolist())
    assert train_ids_set.isdisjoint(val_ids_set), (
        f"Identity leak: {len(train_ids_set & val_ids_set)} overlapping IDs")
    return train_idx, val_idx


class PKBatchSampler(torch.utils.data.Sampler):
    def __init__(self, labels, indices, p=16, k=4, seed=42):
        self.labels = np.asarray(labels, dtype=np.int64)
        self.indices = np.asarray(indices, dtype=np.int64)
        self.p = int(max(2, p))
        self.k = int(max(2, k))
        self.seed = int(seed)
        self.by_label = {}
        for idx in self.indices:
            lab = int(self.labels[idx])
            self.by_label.setdefault(lab, []).append(int(idx))
        self.valid_labels = np.array(sorted(self.by_label.keys()), dtype=np.int64)
        self.batch_size = self.p * self.k
        self.num_batches = max(1, int(math.ceil(len(self.indices) / max(self.batch_size, 1))))

    def __iter__(self):
        rng = np.random.default_rng(self.seed + random.randint(0, 10_000))
        for _ in range(self.num_batches):
            if len(self.valid_labels) <= self.p:
                chosen_labels = self.valid_labels
            else:
                chosen_labels = rng.choice(self.valid_labels, size=self.p, replace=False)
            batch = []
            for lab in chosen_labels:
                idxs = self.by_label[int(lab)]
                replace = len(idxs) < self.k
                picks = rng.choice(idxs, size=self.k, replace=replace)
                batch.extend([int(x) for x in picks])
            rng.shuffle(batch)
            yield batch

    def __len__(self):
        return int(self.num_batches)

def make_qpearl_loaders(dataset, val_split=0.10, batch_size=128, num_workers=2, seed=42):
    n = len(dataset)
    if n == 0:
        raise RuntimeError("Q-PEARL dataset is empty.")

    device_type = getattr(DEVICE, "type", str(DEVICE)).lower()
    use_pin_memory = (device_type == "cuda")
    labels = np.asarray(dataset.labels.cpu().numpy(), dtype=np.int64)

    train_idx, val_idx = split_qpearl_indices(labels, val_split=val_split, seed=seed)

    sampler_mode = str(CONFIG.get("qpearl_train_sampler", "pk")).lower()
    if sampler_mode == "pk":
        train_batch_sampler = PKBatchSampler(
            labels=labels,
            indices=train_idx,
            p=int(CONFIG.get("qpearl_pk_num_ids", 16)),
            k=int(CONFIG.get("qpearl_pk_num_samples", 4)),
            seed=seed,
        )
        train_loader = DataLoader(
            dataset,
            batch_sampler=train_batch_sampler,
            num_workers=int(num_workers),
            pin_memory=use_pin_memory,
        )
    else:
        train_subset = Subset(dataset, train_idx.tolist())
        train_loader = DataLoader(
            train_subset,
            batch_size=int(batch_size),
            shuffle=True,
            num_workers=int(num_workers),
            pin_memory=use_pin_memory,
            drop_last=False,
        )

    val_loader = None
    if len(val_idx) > 0:
        val_subset = Subset(dataset, val_idx.tolist())
        val_loader = DataLoader(
            val_subset,
            batch_size=int(batch_size),
            shuffle=False,
            num_workers=max(0, int(num_workers) // 2),
            pin_memory=use_pin_memory,
            drop_last=False,
        )

    return train_loader, val_loader, train_idx, val_idx




