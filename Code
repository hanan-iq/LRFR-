def qpearl_v2_scan_identity_folders(root: str, min_imgs_per_id: int = 2) -> Dict[str, List[str]]:
    if root is None or not os.path.isdir(root):
        raise FileNotFoundError(f"TinyFace training root is missing: {root}")
    exts = ("*.jpg", "*.jpeg", "*.png", "*.bmp", "*.JPG", "*.JPEG", "*.PNG")
    id_to_paths = {}
    for id_dir in sorted([p for p in Path(root).iterdir() if p.is_dir()]):
        paths = []
        for ext in exts:
            paths.extend(glob.glob(str(id_dir / ext)))
        paths = sorted(paths)
        if len(paths) >= int(min_imgs_per_id):
            id_to_paths[str(id_dir.name)] = paths
    if len(id_to_paths) == 0:
        raise RuntimeError(f"No identities with at least {min_imgs_per_id} images were found in {root}")
    return id_to_paths

def qpearl_v2_official_eval_ids() -> set:
    gallery_csv, probe_csv = find_tinyface_protocol_files(TINYFACE_EVAL_ROOT)
    df_g = read_protocol_csv(gallery_csv)
    df_p = read_protocol_csv(probe_csv)
    return set(df_g["person_id"].astype(str)) | set(df_p["person_id"].astype(str))

def qpearl_v2_make_identity_split(id_to_paths: Dict[str, List[str]], seed: int = SEED):
    eval_ids = qpearl_v2_official_eval_ids()
    before = len(id_to_paths)
    id_to_paths = {pid: paths for pid, paths in id_to_paths.items() if str(pid) not in eval_ids}
    removed = before - len(id_to_paths)
    if removed > 0:
        print(f"[leakage guard] Removed {removed} training identities that overlap official TinyFace evaluation IDs.")
    ids = sorted(id_to_paths.keys())
    max_ids = CONFIG.get("qpearl_v2_max_train_ids", None)
    if max_ids is not None:
        rng = np.random.default_rng(seed)
        ids = sorted(rng.choice(ids, size=min(int(max_ids), len(ids)), replace=False).tolist())
    if len(ids) < 4:
        raise RuntimeError("Not enough identity-disjoint training identities for Q-PEARL-v2.")
    train_ids, dev_ids = train_test_split(
        ids,
        test_size=float(CONFIG["qpearl_v2_dev_ratio"]),
        random_state=seed,
        shuffle=True,
    )
    train_ids = sorted(map(str, train_ids))
    dev_ids = sorted(map(str, dev_ids))
    assert set(train_ids).isdisjoint(dev_ids), "Train and DEV identities overlap."
    assert set(train_ids).isdisjoint(eval_ids), "Train identities overlap official TEST."
    assert set(dev_ids).isdisjoint(eval_ids), "DEV identities overlap official TEST."
    return train_ids, dev_ids, eval_ids, id_to_paths

