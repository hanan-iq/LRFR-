from pathlib import Path
import numpy as np
import pandas as pd
import json

try:
    from scipy.stats import binomtest
except Exception:
    binomtest = None

tf = OBJ3_RESULTS.get("TinyFace", {})
if not isinstance(tf, dict) or "ranks_path" not in tf:
    raise RuntimeError("OBJ3_RESULTS['TinyFace']['ranks_path'] is missing.")

ranks_path = Path(tf["ranks_path"])
if not ranks_path.exists():
    raise FileNotFoundError(f"Ranks file not found: {ranks_path}")

rank_data = np.load(ranks_path, allow_pickle=True)
probe_ranks = np.asarray(rank_data["probe_ranks"], dtype=np.int32)

rank1_hits = (probe_ranks == 0).astype(np.float32)
n = len(rank1_hits)

rank1 = 100.0 * float(np.mean(rank1_hits))

# Bootstrap CI
rng = np.random.default_rng(42)
B = 10000
boot_scores = np.empty(B, dtype=np.float32)

for b in range(B):
    sample = rng.choice(rank1_hits, size=n, replace=True)
    boot_scores[b] = 100.0 * float(np.mean(sample))

ci_low, ci_high = np.percentile(boot_scores, [2.5, 97.5])

# Compare against Stabilized baseline
stabilized_r1 = 56.51 / 100.0
successes = int(rank1_hits.sum())

if binomtest is not None:
    binom_p = float(binomtest(successes, n, p=stabilized_r1, alternative="greater").pvalue)
else:
    binom_p = np.nan

stats_summary = {
    "model": "Q-PEARL-Adapter++",
    "rank1_percent": round(rank1, 3),
    "bootstrap_ci_95_lower": round(float(ci_low), 3),
    "bootstrap_ci_95_upper": round(float(ci_high), 3),
    "n_probes": int(n),
    "successes_rank1": int(successes),
    "baseline_stabilized_rank1_percent": 56.51,
    "binomial_test_p_value": binom_p,
}

