    return model


def qpearl_v2_batch_hard_triplet(
    emb: torch.Tensor,
    labels: torch.Tensor,
    margin: float = 0.20,
):
    """
    AMP-safe batch-hard triplet loss.
    Uses float32 distances to avoid FP16 overflow.
    """
    if emb is None or emb.numel() == 0:
        return torch.tensor(0.0, device=DEVICE)

    emb32 = F.normalize(emb.float(), dim=1)
    dist = (1.0 - emb32 @ emb32.t()).clamp_min(0.0)

    labels = labels.view(-1, 1)
    same = labels.eq(labels.t())

    eye = torch.eye(labels.numel(), dtype=torch.bool, device=emb.device)
    pos_mask = same & (~eye)
    neg_mask = ~same

    valid = pos_mask.any(dim=1) & neg_mask.any(dim=1)

    if valid.sum() == 0:
        return emb32.sum() * 0.0

    hardest_pos = dist.masked_fill(~pos_mask, 0.0).max(dim=1).values
    hardest_neg = dist.masked_fill(~neg_mask, torch.finfo(dist.dtype).max).min(dim=1).values

    return F.relu(hardest_pos[valid] - hardest_neg[valid] + float(margin)).mean()


@torch.no_grad()
def qpearl_v2_extract_for_paths(
    model: nn.Module,
    paths: List[str],
    quality_raw=None,
    batch_size: int = 32,
    view: str = "clean",
) -> np.ndarray:
    """
    Extract Q-PEARL-v2 embeddings safely.
    Extraction uses smaller batches to avoid OOM.
    """
    model.eval()

    if paths is None or len(paths) == 0:
        return np.zeros((0, 512), dtype=np.float32)

    paths = [str(p) for p in paths]

    if quality_raw is None or len(quality_raw) != len(paths):
        quality_raw = [qpearl_v2_compute_quality_for_path(p) for p in paths]

    q_norm = qpearl_v2_normalize_quality(quality_raw)
    feats = []

    safe_bs = int(min(batch_size, 32))

    for start in tqdm(
        range(0, len(paths), safe_bs),
        desc=f"Q-PEARL-v2 extract {view}",
        leave=False,
    ):
        batch_paths = paths[start:start + safe_bs]
        batch_quality = q_norm[start:start + safe_bs]

        xs = []
        qs = []

        for p, q in zip(batch_paths, batch_quality):
            img = safe_imread(str(p))

            if img is None:
                img = np.zeros((112, 112, 3), dtype=np.uint8)

            if view == "lr":
                img = qpearl_v2_degrade_lr(img)
            elif view == "global":
                img = qpearl_v2_global_transform(img)
            elif view == "elastic":
                img = qpearl_v2_elastic_deform(img)

            xs.append(qpearl_v2_bgr_to_tensor(img))
            qs.append(float(q))

        x = torch.stack(xs).to(DEVICE, non_blocking=True)
        q = torch.tensor(qs, dtype=torch.float32, device=DEVICE)

        emb = model(x, q)
        emb = emb.detach().cpu().numpy().astype(np.float32)
        feats.append(emb)

        del x, q, emb
        torch.cuda.empty_cache()

    if len(feats) == 0:
        return np.zeros((0, 512), dtype=np.float32)

    return l2n_rows(np.vstack(feats))


def qpearl_v2_make_dev_gallery_probe():
    """
    Corrected validation:
    DEV gallery and DEV probes come from the same DEV identities.
    Train identities are not used as validation gallery.
    """
    dev_paths = QPEARL_V2_CACHE.get("dev_paths", [])
    dev_ids = QPEARL_V2_CACHE.get("dev_ids", [])
    dev_quality = QPEARL_V2_CACHE.get("quality_dev", None)

    if dev_paths is None or len(dev_paths) == 0:
        raise RuntimeError("Q-PEARL-v2 DEV paths are empty.")

    if dev_ids is None or len(dev_ids) != len(dev_paths):
        raise RuntimeError("Q-PEARL-v2 DEV identity labels are missing or mismatched.")

    if dev_quality is None or len(dev_quality) != len(dev_paths):
        dev_quality = [qpearl_v2_compute_quality_for_path(p) for p in dev_paths]

    dev = pd.DataFrame({
        "path": [str(p) for p in dev_paths],
        "person_id": [str(x) for x in dev_ids],
        "quality": list(dev_quality),
    })

    dev = dev.dropna(subset=["path", "person_id"]).reset_index(drop=True)

    valid_ids = dev["person_id"].value_counts()
    valid_ids = valid_ids[valid_ids >= 2].index.tolist()

    dev = dev[dev["person_id"].isin(valid_ids)].reset_index(drop=True)

    if dev.empty:
        raise RuntimeError(
            "DEV validation needs at least two images per DEV identity. "
            "No valid DEV identities were found."
        )

    gallery_rows = []
    probe_rows = []

    for pid, grp in dev.groupby("person_id"):
        grp = grp.sample(frac=1.0, random_state=SEED).reset_index(drop=True)

        if len(grp) < 2:
            continue

        gallery_rows.append(grp.iloc[0])

        for i in range(1, len(grp)):
            probe_rows.append(grp.iloc[i])

    if len(gallery_rows) == 0 or len(probe_rows) == 0:
        raise RuntimeError(
            "Corrected DEV validation could not build gallery/probe split. "
            "Each DEV identity must have at least two images."
        )

    gallery = pd.DataFrame(gallery_rows).reset_index(drop=True)
    probes = pd.DataFrame(probe_rows).reset_index(drop=True)

    gallery_ids = set(gallery["person_id"].astype(str).tolist())
    probe_ids = set(probes["person_id"].astype(str).tolist())

    assert gallery_ids.issubset(probe_ids), (
        "Invalid DEV validation split: some gallery identities have no matching probe."
    )

    print(
        f"[OK] Corrected DEV validation split: "
        f"gallery={len(gallery)}, probes={len(probes)}, identities={len(gallery_ids)}"
    )

    return gallery, probes


@torch.no_grad()
def qpearl_v2_validate(model: nn.Module, batch_size: int = 16) -> Dict[str, float]:
    """
    Validate Q-PEARL-v2 on identity-disjoint DEV data.
    """
    gallery, probes = qpearl_v2_make_dev_gallery_probe()

    G = qpearl_v2_extract_for_paths(
        model=model,
        paths=gallery["path"].astype(str).tolist(),
        quality_raw=gallery["quality"].values,
        batch_size=batch_size,
        view="clean",
    )

    P = qpearl_v2_extract_for_paths(
        model=model,
        paths=probes["path"].astype(str).tolist(),
        quality_raw=probes["quality"].values,
        batch_size=batch_size,
        view="lr",
    )

    if G.shape[0] == 0 or P.shape[0] == 0:
        raise RuntimeError("Q-PEARL-v2 DEV validation produced empty embeddings.")

    out = evaluate_identification_chunked(
        P,
        probes["person_id"].astype(str).values,
        [(G, gallery["person_id"].astype(str).values)],
        ranks=(1, 5, 20),
        probe_batch=int(qpearl_v2_cfg("tinyface_probe_batch", 256)),
        aux_neg_per_probe=0,
        seed=SEED,
    )

    return out


def qpearl_v2_select_augmented_view(batch, step_index: int):
    """
    Memory-safe paired training:
    Instead of clean + lr + global + elastic together,
    use clean + one augmented view per batch.
    The augmented view rotates across batches.
    """
    mode = step_index % 3

    if mode == 0:
        return batch["x_lr"], "lr"

    if mode == 1:
        return batch["x_global"], "global"

    return batch["x_elastic"], "elastic"


def qpearl_v2_train_or_load():
    """
    Memory-safe Q-PEARL-v2 training.

    Main fix:
    Does not concatenate four views into one large Swin-B forward pass.
    Uses clean + one rotating augmented view per batch.
    """
    torch.cuda.empty_cache()
    gc.collect()

    train_loader, dev_loader, id_to_label = qpearl_v2_make_loaders()
    num_classes = len(id_to_label)

    if num_classes < 2:
        raise RuntimeError("Q-PEARL-v2 training needs at least two training identities.")

    model = QPEARLV2Model(embedding_dim=512).to(DEVICE)
    model = qpearl_v2_enable_memory_saving(model)

    head = ArcFaceHead(
        dim=512,
        num_classes=num_classes,
        s=float(qpearl_v2_cfg("qpearl_v2_arcface_s", 32.0)),
        m=float(qpearl_v2_cfg("qpearl_v2_arcface_m", 0.20)),
    ).to(DEVICE)

    ckpt = qpearl_v2_checkpoint_path()
    force_retrain = bool(qpearl_v2_cfg("qpearl_v2_force_retrain", False))

    if ckpt.exists() and not force_retrain:
        state = torch.load(ckpt, map_location=DEVICE)
        old_r1 = float(state.get("best_dev", {}).get("rank_1", 0.0))

        if old_r1 > 0.0:
            model.load_state_dict(state["model"], strict=False)

            if "head" in state:
                head.load_state_dict(state["head"], strict=False)

            print(f"[OK] Loaded Q-PEARL-v2 checkpoint: {ckpt}")
            print(f"[OK] Loaded checkpoint DEV Rank-1={100.0 * old_r1:.2f}%")
            return model, head, id_to_label, state

        print(
            "[WARN] Existing Q-PEARL-v2 checkpoint has zero or missing DEV Rank-1. "
            "It will be ignored and retrained."
        )

    params = list(qpearl_v2_trainable_parameters(model, head))

    if len(params) == 0:
        raise RuntimeError("No trainable parameters found for Q-PEARL-v2.")

    optimizer = torch.optim.AdamW(
        params,
        lr=float(qpearl_v2_cfg("qpearl_v2_lr", 1e-4)),
        weight_decay=float(qpearl_v2_cfg("qpearl_v2_weight_decay", 1e-4)),
    )

    scaler = torch.cuda.amp.GradScaler(enabled=torch.cuda.is_available())

    best_r1 = -1.0
    best_state = None
    patience = 0
    history = []

    epochs = int(qpearl_v2_cfg("qpearl_v2_epochs", 8))
    early_stop_patience = int(qpearl_v2_cfg("qpearl_v2_early_stop_patience", 3))
    train_batch_size = int(qpearl_v2_cfg("qpearl_v2_batch_size", 4))
    grad_accum_steps = int(qpearl_v2_cfg("qpearl_v2_grad_accum_steps", 4))

    lambda_id = float(qpearl_v2_cfg("qpearl_v2_lambda_id", 1.0))
    lambda_kd = float(qpearl_v2_cfg("qpearl_v2_lambda_kd", 0.30))
    lambda_cons = float(qpearl_v2_cfg("qpearl_v2_lambda_cons", 0.25))
    lambda_triplet = float(qpearl_v2_cfg("qpearl_v2_lambda_triplet", 0.10))
    triplet_margin = float(qpearl_v2_cfg("qpearl_v2_triplet_margin", 0.20))

    print(f"[INFO] Memory-safe training batch_size={train_batch_size}, grad_accum_steps={grad_accum_steps}")
    print("[INFO] Training uses clean + one rotating augmented view per batch.")

    global_step = 0

    for epoch in range(1, epochs + 1):
        model.train()
        head.train()

        losses = []
        loss_id_list = []
        loss_kd_list = []
        loss_cons_list = []
        loss_trip_list = []

        optimizer.zero_grad(set_to_none=True)

        for batch_idx, batch in enumerate(
            tqdm(train_loader, desc=f"Q-PEARL-v2 train epoch {epoch}", leave=False)
        ):
            x_clean = batch["x_clean"].to(DEVICE, non_blocking=True)
            x_aug, aug_name = qpearl_v2_select_augmented_view(batch, global_step)
            x_aug = x_aug.to(DEVICE, non_blocking=True)

            teacher = batch["teacher"].to(DEVICE, non_blocking=True)
            teacher = F.normalize(teacher.float(), dim=1)

            q = batch["quality"].to(DEVICE, non_blocking=True).float()
            y = batch["label"].to(DEVICE, non_blocking=True).long()

            y_pair = y.repeat(2)
            q_pair = q.repeat(2)

            with torch.cuda.amp.autocast(enabled=torch.cuda.is_available()):
                emb_clean = model(x_clean, q)
                emb_aug = model(x_aug, q)

                emb_pair = torch.cat([emb_clean, emb_aug], dim=0)

                logits = head(emb_pair, y_pair)
                loss_id = F.cross_entropy(logits, y_pair)

                loss_kd = (
                    1.0 - F.cosine_similarity(
                        F.normalize(emb_clean.float(), dim=1),
                        teacher,
                        dim=1,
                    )
                ).mean()

                loss_cons = (
                    1.0 - F.cosine_similarity(emb_clean, emb_aug, dim=1)
                ).mean()

                loss_trip = qpearl_v2_batch_hard_triplet(
                    emb_pair,
                    y_pair,
                    margin=triplet_margin,
                )

                loss = (
                    lambda_id * loss_id
                    + lambda_kd * loss_kd
                    + lambda_cons * loss_cons
                    + lambda_triplet * loss_trip
                )

                loss_for_backward = loss / float(grad_accum_steps)

            scaler.scale(loss_for_backward).backward()

            should_step = ((batch_idx + 1) % grad_accum_steps == 0) or ((batch_idx + 1) == len(train_loader))

            if should_step:
                scaler.unscale_(optimizer)
                torch.nn.utils.clip_grad_norm_(params, max_norm=5.0)
                scaler.step(optimizer)
                scaler.update()
                optimizer.zero_grad(set_to_none=True)

            losses.append(float(loss.detach().cpu()))
            loss_id_list.append(float(loss_id.detach().cpu()))
            loss_kd_list.append(float(loss_kd.detach().cpu()))
            loss_cons_list.append(float(loss_cons.detach().cpu()))
            loss_trip_list.append(float(loss_trip.detach().cpu()))

            del x_clean, x_aug, teacher, q, y, y_pair, q_pair
            del emb_clean, emb_aug, emb_pair, logits
            del loss_id, loss_kd, loss_cons, loss_trip, loss, loss_for_backward

            if (global_step + 1) % 20 == 0:
                torch.cuda.empty_cache()

            global_step += 1

        torch.cuda.empty_cache()
        gc.collect()

        val = qpearl_v2_validate(
            model,
            batch_size=16,
        )

        val_r1 = float(val.get("rank_1", 0.0))
        val_r5 = float(val.get("rank_5", 0.0))
        val_r20 = float(val.get("rank_20", 0.0))

        row = {
            "epoch": epoch,
            "loss": float(np.mean(losses)) if len(losses) else float("nan"),
            "loss_id": float(np.mean(loss_id_list)) if len(loss_id_list) else float("nan"),
            "loss_kd": float(np.mean(loss_kd_list)) if len(loss_kd_list) else float("nan"),
            "loss_cons": float(np.mean(loss_cons_list)) if len(loss_cons_list) else float("nan"),
            "loss_trip": float(np.mean(loss_trip_list)) if len(loss_trip_list) else float("nan"),
            "dev_rank1": val_r1,
            "dev_rank5": val_r5,
            "dev_rank20": val_r20,
        }

        history.append(row)

        print(
            f"[epoch {epoch:02d}] "
            f"loss={row['loss']:.4f} "
            f"id={row['loss_id']:.4f} "
            f"kd={row['loss_kd']:.4f} "
            f"cons={row['loss_cons']:.4f} "
            f"trip={row['loss_trip']:.4f} "
            f"DEV R1={100.0 * val_r1:.2f}% "
            f"R5={100.0 * val_r5:.2f}% "
            f"R20={100.0 * val_r20:.2f}%"
        )

        if val_r1 > best_r1:
            best_r1 = val_r1
            patience = 0

            best_state = {
                "model": {k: v.detach().cpu() for k, v in model.state_dict().items()},
                "head": {k: v.detach().cpu() for k, v in head.state_dict().items()},
                "id_to_label": id_to_label,
                "history": history,
                "best_dev": val,
                "config": dict(CONFIG),
                "baseline_lock": BASELINE_LOCK,
                "memory_safe": True,
                "views_mode": "clean_plus_rotating_augmented_view",
            }

            torch.save(best_state, ckpt)
            pd.DataFrame(history).to_csv(
                RESULTS_DIR / "qpearl_v2_training_history.csv",
                index=False,
            )

            print(
                f"[OK] Saved best Q-PEARL-v2 checkpoint, "
                f"DEV Rank-1={100.0 * best_r1:.2f}%"
            )

        else:
            patience += 1

            if patience >= early_stop_patience:
                print("[early stop] DEV Rank-1 did not improve.")
                break

    if best_state is None:
        if ckpt.exists():
            best_state = torch.load(ckpt, map_location=DEVICE)
        else:
            raise RuntimeError("Q-PEARL-v2 training finished without a valid checkpoint.")

    model.load_state_dict(best_state["model"], strict=False)

    if "head" in best_state:
        head.load_state_dict(best_state["head"], strict=False)

    return model, head, id_to_label, best_state


