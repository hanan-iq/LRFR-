    print("Q-PEARL-Adapter++ TEST Rank-20:", 100 * adapter_tf["rank_20"])

    current_final = OBJ3_RESULTS.get("TinyFace", OBJ3_RESULTS.get("TinyFace_QPEARL_v2_fusion_no_reranker", {}))
    candidates = [
        ("Current selected before adapter", current_final),
