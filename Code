from typing import Dict, List, Tuple
from sklearn.metrics import roc_curve, auc
import re

CONFIG.setdefault("qpearl_adapter_enabled", True)
CONFIG.setdefault("qpearl_adapter_quality_bins", 4)
CONFIG.setdefault("qpearl_adapter_modes", ["raw", "z", "quality_z"])
CONFIG.setdefault("qpearl_adapter_weight_grid", [0.10, 0.20, 0.30, 0.40, 0.50, 0.60, 0.70, 0.80, 0.90])
CONFIG.setdefault("qpearl_adapter_selection_policy", "rank1_rank5_rank20_map")

if not CONFIG["qpearl_adapter_enabled"]:
    print("[SKIP] CONFIG['qpearl_adapter_enabled'] is False.")
else:
    required_globals = [
        "QPEARL_V2_DEV_STAGE", "R100_P", "R100_G_ALL", "V2_P", "V2_G_ALL",
        "P_ids", "G_ALL_IDS", "P_q", "qpearl_v2_compute_map_from_ranks",
        "qpearl_v2_cmc_from_ranks", "RESULTS_DIR", "OBJ3_RESULTS", "l2n_rows"
    ]
    missing = [name for name in required_globals if name not in globals()]
    if missing:
        raise RuntimeError(
            "Q-PEARL-Adapter++ missing required variables. "
            "Run Sections 10H and Cell 17 first. Cell 17B and 17C are optional but recommended. "
            f"Missing: {missing}"
        )

    def qpearl_adapter_metric_tuple(res: Dict[str, float]) -> Tuple[float, float, float, float]:
        """Primary Rank-1, secondary Rank-5, tertiary Rank-20, then mAP."""
        return (
            float(res.get("rank_1", -1.0)),
            float(res.get("rank_5", -1.0)),
            float(res.get("rank_20", -1.0)),
            float(res.get("mAP", -1.0)),
        )

    def qpearl_adapter_quality_edges(q: np.ndarray, n_bins: int = 4) -> np.ndarray:
        q = np.asarray(q, dtype=np.float32).reshape(-1)
        q = np.nan_to_num(q, nan=0.5, posinf=1.0, neginf=0.0)
        if q.size == 0:
            return np.asarray([-np.inf, np.inf], dtype=np.float32)
        qs = np.linspace(0.0, 1.0, int(n_bins) + 1)
        edges = np.quantile(q, qs).astype(np.float32)
        edges[0] = -np.inf
        edges[-1] = np.inf
        return edges

    def qpearl_adapter_bin_index(q_value: float, edges: np.ndarray) -> int:
        return int(np.clip(np.searchsorted(edges, float(q_value), side="right") - 1, 0, len(edges) - 2))

    def qpearl_adapter_zscore(scores: np.ndarray, eps: float = 1e-6) -> np.ndarray:
        scores = np.asarray(scores, dtype=np.float32)
        mu = scores.mean(axis=1, keepdims=True)
        sd = scores.std(axis=1, keepdims=True)
        return (scores - mu) / np.maximum(sd, eps)

    def qpearl_adapter_scores(sr: np.ndarray, sv: np.ndarray, q: np.ndarray, cfg: Dict[str, float]) -> np.ndarray:
        """Score-space Q-PEARL-Adapter++ recalibration."""
        mode = str(cfg.get("mode", "z"))
        wr = float(cfg.get("w_r100", 0.40))
        wv = float(cfg.get("w_v2", 0.60))
        q = np.asarray(q, dtype=np.float32).reshape(-1, 1)
        q = np.nan_to_num(q, nan=0.5, posinf=1.0, neginf=0.0)

        if mode == "raw":
            a = sr.astype(np.float32)
            b = sv.astype(np.float32)
        elif mode == "quality_z":
            a = qpearl_adapter_zscore(sr)
            b = qpearl_adapter_zscore(sv)
            b = b * (1.0 + 0.25 * (1.0 - q))
        else:
            a = qpearl_adapter_zscore(sr)
            b = qpearl_adapter_zscore(sv)

        return (wr * a + wv * b).astype(np.float32)

    def qpearl_adapter_eval_scores(
        sr: np.ndarray,
        sv: np.ndarray,
        P_ids_eval: np.ndarray,
        G_ids_eval: np.ndarray,
        P_q_eval: np.ndarray,
        cfg_by_bin: List[Dict[str, float]],
        edges: np.ndarray,
        topk: int = 100,
        name: str = "Q-PEARL-Adapter++",
        collect_roc: bool = False,
        rng_seed: int = 42,
        neg_per_probe: int = 100,
    ) -> Dict[str, float]:
        """Evaluate from precomputed R100 and Q-PEARL-v2 score matrices."""
        P_ids_eval = np.asarray(P_ids_eval).astype(str)
        G_ids_eval = np.asarray(G_ids_eval).astype(str)
        P_q_eval = np.asarray(P_q_eval, dtype=np.float32).reshape(-1)

        n = len(P_ids_eval)
        ranks = np.full(n, -1, dtype=np.int32)
        hits = {1: 0, 5: 0, 10: 0, 20: 0}
        max_rank = min(max(20, int(topk)), sr.shape[1])
        if max_rank <= 0:
            raise RuntimeError("Q-PEARL-Adapter++ received an empty gallery.")

        scores = np.zeros_like(sr, dtype=np.float32)
        bin_ids = np.asarray([qpearl_adapter_bin_index(qv, edges) for qv in P_q_eval], dtype=np.int32)
        for b in np.unique(bin_ids):
            mask = bin_ids == int(b)
            cfg = cfg_by_bin[int(b)] if int(b) < len(cfg_by_bin) else cfg_by_bin[0]
            scores[mask] = qpearl_adapter_scores(sr[mask], sv[mask], P_q_eval[mask], cfg)

        roc_pos_scores = []
        roc_neg_scores = []
        if collect_roc:
            rng = np.random.default_rng(int(rng_seed))
            distractor_pool = np.where(G_ids_eval == "-1")[0]
            for ii, true_id in enumerate(P_ids_eval):
                pos_idx = np.where(G_ids_eval == true_id)[0]
                if len(pos_idx) > 0:
                    roc_pos_scores.append(float(np.max(scores[ii, pos_idx])))
                if len(distractor_pool) > 0:
                    neg_pool = distractor_pool
                else:
                    neg_pool = np.where(G_ids_eval != true_id)[0]
                if len(neg_pool) > 0:
                    take = min(int(neg_per_probe), len(neg_pool))
                    if take > 0:
                        neg_idx = rng.choice(neg_pool, size=take, replace=False)
                        roc_neg_scores.extend(scores[ii, neg_idx].astype(np.float32).tolist())

        idx = np.argpartition(-scores, kth=max_rank - 1, axis=1)[:, :max_rank]
        scr = np.take_along_axis(scores, idx, axis=1)
        order = np.argsort(-scr, axis=1)
        idx = np.take_along_axis(idx, order, axis=1)
        pred_ids = G_ids_eval[idx]

        for i, true_id in enumerate(P_ids_eval):
            loc = np.where(pred_ids[i] == true_id)[0]
            if len(loc) > 0:
                r = int(loc[0])
                ranks[i] = r
                for kk in hits:
                    if r < kk:
                        hits[kk] += 1

        out = {f"rank_{k}": float(v / max(1, n)) for k, v in hits.items()}
        out["mAP"] = qpearl_v2_compute_map_from_ranks(ranks)
        out["probe_ranks"] = ranks
        out["name"] = name
        out[f"top{max_rank}_recall"] = float(np.mean(ranks >= 0)) if n else float("nan")
        if max_rank >= 100:
            out["top100_recall"] = out[f"top{max_rank}_recall"]
        if collect_roc:
            out["roc_pos_scores"] = np.asarray(roc_pos_scores, dtype=np.float32)
            out["roc_neg_scores"] = np.asarray(roc_neg_scores, dtype=np.float32)
        return out

    def qpearl_adapter_eval_chunked(
        P_r100: np.ndarray,
        G_r100: np.ndarray,
        P_v2: np.ndarray,
        G_v2: np.ndarray,
        P_ids_eval: np.ndarray,
        G_ids_eval: np.ndarray,
        P_q_eval: np.ndarray,
        cfg_by_bin: List[Dict[str, float]],
        edges: np.ndarray,
        probe_batch: int = 256,
        topk: int = 100,
        name: str = "Q-PEARL-Adapter++",
        collect_roc: bool = False,
        roc_prefix: str = "qpearl_adapter_plus_final",
    ) -> Dict[str, float]:
        """Chunked TEST evaluation to avoid materializing a large score matrix."""
        P_r100 = l2n_rows(P_r100); G_r100 = l2n_rows(G_r100)
        P_v2 = l2n_rows(P_v2); G_v2 = l2n_rows(G_v2)
        P_ids_eval = np.asarray(P_ids_eval).astype(str)
        G_ids_eval = np.asarray(G_ids_eval).astype(str)
        P_q_eval = np.asarray(P_q_eval, dtype=np.float32).reshape(-1)

        if not (len(P_r100) == len(P_v2) == len(P_ids_eval) == len(P_q_eval)):
            raise RuntimeError("Q-PEARL-Adapter++ probe arrays have inconsistent lengths.")
        if not (len(G_r100) == len(G_v2) == len(G_ids_eval)):
            raise RuntimeError("Q-PEARL-Adapter++ gallery arrays have inconsistent lengths.")

        n = len(P_ids_eval)
        ranks = np.full(n, -1, dtype=np.int32)
        hits = {1: 0, 5: 0, 10: 0, 20: 0}
        max_rank = min(max(20, int(topk)), len(G_ids_eval))
        if max_rank <= 0:
            raise RuntimeError("Q-PEARL-Adapter++ received an empty TEST gallery.")

        roc_pos_scores = []
        roc_neg_scores = []
        neg_per_probe = int(CONFIG.get("tinyface_aux_neg_per_probe", 100)) if "CONFIG" in globals() else 100
        seed_base = int(globals().get("SEED", 42))

        for start in tqdm(range(0, n, int(probe_batch)), desc=f"Eval {name}", leave=False):
            stop = min(start + int(probe_batch), n)
            sr = np.dot(P_r100[start:stop], G_r100.T).astype(np.float32)
            sv = np.dot(P_v2[start:stop], G_v2.T).astype(np.float32)
            chunk_res = qpearl_adapter_eval_scores(
                sr, sv,
                P_ids_eval[start:stop], G_ids_eval,
                P_q_eval[start:stop],
                cfg_by_bin, edges,
                topk=max_rank,
                name=name,
                collect_roc=collect_roc,
                rng_seed=seed_base + int(start),
                neg_per_probe=neg_per_probe,
            )
            chunk_ranks = np.asarray(chunk_res["probe_ranks"], dtype=np.int32)
            if collect_roc:
                roc_pos_scores.extend(np.asarray(chunk_res.get("roc_pos_scores", []), dtype=np.float32).tolist())
                roc_neg_scores.extend(np.asarray(chunk_res.get("roc_neg_scores", []), dtype=np.float32).tolist())
            ranks[start:stop] = chunk_ranks
            for kk in hits:
                hits[kk] += int(np.sum((chunk_ranks >= 0) & (chunk_ranks < kk)))

        out = {f"rank_{k}": float(v / max(1, n)) for k, v in hits.items()}
        out["mAP"] = qpearl_v2_compute_map_from_ranks(ranks)
        out["probe_ranks"] = ranks
        out["name"] = name
        out[f"top{max_rank}_recall"] = float(np.mean(ranks >= 0)) if n else float("nan")
        if max_rank >= 100:
            out["top100_recall"] = out[f"top{max_rank}_recall"]

        if collect_roc and len(roc_pos_scores) > 0 and len(roc_neg_scores) > 0:
            y_true = np.concatenate([
                np.ones(len(roc_pos_scores), dtype=np.int32),
                np.zeros(len(roc_neg_scores), dtype=np.int32),
            ])
            y_score = np.concatenate([
                np.asarray(roc_pos_scores, dtype=np.float32),
                np.asarray(roc_neg_scores, dtype=np.float32),
            ])
            fpr, tpr, thresholds = roc_curve(y_true, y_score)
            out["aux_auc"] = float(auc(fpr, tpr))
            fnr = 1.0 - tpr
            eer_idx = int(np.nanargmin(np.abs(fpr - fnr)))
            out["aux_eer"] = float(fpr[eer_idx])

            safe_prefix = re.sub(r"[^A-Za-z0-9_]+", "_", str(roc_prefix)).strip("_")
            roc_path = RESULTS_DIR / f"{safe_prefix}_roc.npz"
            np.savez_compressed(
                roc_path,
                fpr=fpr.astype(np.float32),
                tpr=tpr.astype(np.float32),
                thresholds=np.asarray(thresholds, dtype=np.float32),
                auc=np.asarray([out["aux_auc"]], dtype=np.float32),
                eer=np.asarray([out["aux_eer"]], dtype=np.float32),
                n_pos=np.asarray([len(roc_pos_scores)], dtype=np.int32),
                n_neg=np.asarray([len(roc_neg_scores)], dtype=np.int32),
            )
            out["roc_path"] = str(roc_path)
            out["roc_num_pos"] = int(len(roc_pos_scores))
            out["roc_num_neg"] = int(len(roc_neg_scores))
        else:
            out.setdefault("aux_auc", float("nan"))
            out.setdefault("aux_eer", float("nan"))

        return out

    def qpearl_adapter_grid() -> List[Dict[str, float]]:
        grid = []
        for mode in CONFIG["qpearl_adapter_modes"]:
            for wr in CONFIG["qpearl_adapter_weight_grid"]:
                wr = float(wr)
                grid.append({"mode": str(mode), "w_r100": wr, "w_v2": 1.0 - wr})
        return grid

    def qpearl_adapter_select_on_dev() -> Tuple[List[Dict[str, float]], np.ndarray, pd.DataFrame]:
        Pdr = l2n_rows(QPEARL_V2_DEV_STAGE["P_r100"])
        Gdr = l2n_rows(QPEARL_V2_DEV_STAGE["G_r100"])
        Pdv = l2n_rows(QPEARL_V2_DEV_STAGE["P_v2"])
        Gdv = l2n_rows(QPEARL_V2_DEV_STAGE["G_v2"])
        Pdid = np.asarray(QPEARL_V2_DEV_STAGE["P_ids"]).astype(str)
        Gdid = np.asarray(QPEARL_V2_DEV_STAGE["G_ids"]).astype(str)
        Pdq = np.asarray(QPEARL_V2_DEV_STAGE["P_q"], dtype=np.float32)

        sr_dev = np.dot(Pdr, Gdr.T).astype(np.float32)
        sv_dev = np.dot(Pdv, Gdv.T).astype(np.float32)
        n_bins = int(CONFIG["qpearl_adapter_quality_bins"])
        edges = qpearl_adapter_quality_edges(Pdq, n_bins=n_bins)
        grid = qpearl_adapter_grid()
        rows = []
        cfg_by_bin = []

        best_global_cfg = None
        best_global_res = None
        global_edges = np.asarray([-np.inf, np.inf], dtype=np.float32)
        for cfg in grid:
            res = qpearl_adapter_eval_scores(
                sr_dev, sv_dev, Pdid, Gdid, Pdq,
                [cfg], global_edges,
                topk=20,
                name="DEV global adapter",
            )
            if best_global_res is None or qpearl_adapter_metric_tuple(res) > qpearl_adapter_metric_tuple(best_global_res):
                best_global_cfg, best_global_res = dict(cfg), dict(res)

        for b in range(n_bins):
            mask = np.asarray([qpearl_adapter_bin_index(qv, edges) == b for qv in Pdq], dtype=bool)
            if mask.sum() < 5:
                cfg_by_bin.append(dict(best_global_cfg))
                rows.append({
                    "bin": b, "n_dev": int(mask.sum()), "mode": best_global_cfg["mode"],
                    "w_r100": best_global_cfg["w_r100"], "w_v2": best_global_cfg["w_v2"],
                    "rank_1": best_global_res["rank_1"], "rank_5": best_global_res["rank_5"],
                    "rank_20": best_global_res["rank_20"], "mAP": best_global_res["mAP"],
                    "note": "fallback_global"
                })
                continue

            best_cfg = None
            best_res = None
            for cfg in grid:
                res = qpearl_adapter_eval_scores(
                    sr_dev[mask], sv_dev[mask], Pdid[mask], Gdid, Pdq[mask],
                    [cfg], global_edges,
                    topk=20,
                    name=f"DEV bin {b} adapter",
                )
                if best_res is None or qpearl_adapter_metric_tuple(res) > qpearl_adapter_metric_tuple(best_res):
                    best_cfg, best_res = dict(cfg), dict(res)
            cfg_by_bin.append(dict(best_cfg))
            rows.append({
                "bin": b, "n_dev": int(mask.sum()), "mode": best_cfg["mode"],
                "w_r100": best_cfg["w_r100"], "w_v2": best_cfg["w_v2"],
                "rank_1": best_res["rank_1"], "rank_5": best_res["rank_5"],
                "rank_20": best_res["rank_20"], "mAP": best_res["mAP"],
                "note": "selected_on_bin"
            })

        dev_df = pd.DataFrame(rows)
        return cfg_by_bin, edges, dev_df

    def qpearl_adapter_attach_artifacts(result: Dict[str, float], prefix: str) -> Dict[str, float]:
        ranks = np.asarray(result.get("probe_ranks", []), dtype=np.int32)
        if ranks.size == 0:
            return result
        rank_grid, cmc = qpearl_v2_cmc_from_ranks(ranks, max_rank=100)
        ranks_path = RESULTS_DIR / f"{prefix}_ranks.npz"
        cmc_path = RESULTS_DIR / f"{prefix}_cmc.npz"
        np.savez_compressed(ranks_path, probe_ranks=ranks, probe_quality=P_q, probe_ids=P_ids)
        np.savez_compressed(cmc_path, ranks=rank_grid, cmc=cmc)
        result["ranks_path"] = str(ranks_path)
        result["cmc_path"] = str(cmc_path)
        return result

    print("Selecting Q-PEARL-Adapter++ score calibration on DEV only...")
    adapter_cfg_by_bin, adapter_edges, adapter_dev_df = qpearl_adapter_select_on_dev()
    adapter_cfg_path = RESULTS_DIR / "qpearl_adapter_dev_selected_config.csv"
